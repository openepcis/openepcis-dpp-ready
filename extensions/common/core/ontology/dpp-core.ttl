    rdfs:label "Compliance Status"@en ;
    rdfs:comment "Current compliance status."@en ;
    rdfs:range xsd:boolean ;
    rdfs:isDefinedBy <https://ref.openepcis.io/extensions/common/core/> .

# =============================================================================
