    rdfs:domain dpp:FacilityInformation ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://ref.openepcis.io/extensions/common/core/> .

dpp:facilityCertifications
    a owl:ObjectProperty ;
