{
  "@context": {
    "@version": 1.1,
    "dpp": "https://ref.openepcis.io/extensions/common/core/",
    "gs1": "https://ref.gs1.org/voc/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "cv":      "http://data.europa.eu/m8g/",
    "cccev":   "http://data.europa.eu/m8g/",
    "cpsv":    "http://purl.org/vocab/cpsv#",
    "locn":    "http://www.w3.org/ns/locn#",
    "adms":    "http://www.w3.org/ns/adms#",
    "org":     "http://www.w3.org/ns/org#",
    "foaf":    "http://xmlns.com/foaf/0.1/",
    "skos":    "http://www.w3.org/2004/02/skos/core#",
    "dcterms": "http://purl.org/dc/terms/",
    "prov":    "http://www.w3.org/ns/prov#",
    "time":    "http://www.w3.org/2006/time#",

    "Requirement":         "cccev:Requirement",
    "RequirementGroup":    "cccev:RequirementGroup",
    "Constraint":          "cccev:Constraint",
    "InformationConcept":  "cccev:InformationConcept",
    "InformationRequirement": "cccev:InformationRequirement",
    "Evidence":            "cccev:Evidence",
    "EvidenceType":        "cccev:EvidenceType",
    "SupportedValue":      "cccev:SupportedValue",
    "hasRequirement":      { "@id": "cccev:hasRequirement", "@type": "@id", "@container": "@set" },
    "hasConcept":          { "@id": "cccev:hasConcept", "@type": "@id", "@container": "@set" },
    "hasConstraint":       { "@id": "cccev:hasConstraint", "@type": "@id", "@container": "@set" },
    "hasSupportedValue":   { "@id": "cccev:hasSupportedValue", "@type": "@id", "@container": "@set" },
    "providesEvidence":    { "@id": "cccev:providesEvidence", "@type": "@id", "@container": "@set" },

    "PublicOrganisation":  "cv:PublicOrganisation",
    "ContactPoint":        "cv:ContactPoint",
    "ReferenceFramework":  "cv:ReferenceFramework",
    "ImageObject":         "cv:ImageObject",
    "ChangeEvent":         "org:ChangeEvent",
    "OrganizationalUnit":  "org:OrganizationalUnit",
    "Organization":        "org:Organization",
    "contactPoint":        { "@id": "cv:contactPoint", "@type": "@id" },
    "contactPage":         { "@id": "cv:contactPage", "@type": "@id" },
    "email":               "cv:email",
    "telephone":           "cv:telephone",
    "openingHours":        "cv:openingHours",
    "specialOpeningHoursSpecification": "cv:specialOpeningHoursSpecification",
    "logo":                { "@id": "cv:logo", "@type": "@id" },
    "hasFormalFramework":  { "@id": "cv:hasFormalFramework", "@type": "@id" },
    "homepage":            { "@id": "foaf:homepage", "@type": "@id" },
    "hasUnit":             { "@id": "org:hasUnit", "@type": "@id", "@container": "@set" },
    "unitOf":              { "@id": "org:unitOf", "@type": "@id" },
    "hasMember":           { "@id": "org:hasMember", "@type": "@id", "@container": "@set" },
    "memberOf":            { "@id": "org:memberOf", "@type": "@id" },
    "hasSubOrganization":  { "@id": "org:hasSubOrganization", "@type": "@id", "@container": "@set" },
    "subOrganizationOf":   { "@id": "org:subOrganizationOf", "@type": "@id" },
    "changedBy":           { "@id": "org:changedBy", "@type": "@id" },
    "resultedFrom":        { "@id": "org:resultedFrom", "@type": "@id" },

    "LegalEntity":         "cv:LegalEntity",
    "legalName":           "cv:legalName",
    "companyActivity":     "cv:companyActivity",
    "companyStatus":       "cv:companyStatus",
    "companyType":         "cv:companyType",
    "registeredAddress":   { "@id": "cv:registeredAddress", "@type": "@id" },

    "Person":              "schema:Person",
    "givenName":           "foaf:givenName",
    "familyName":          "foaf:familyName",
    "patronymicName":      "cv:patronymicName",
    "dateOfBirth":         { "@id": "schema:birthDate", "@type": "xsd:date" },
    "gender":              "cv:gender",
    "citizenship":         { "@id": "cv:citizenship", "@type": "@id" },
    "residency":           { "@id": "cv:residency", "@type": "@id" },

    "Address":             "locn:Address",
    "Location":            "locn:Location",
    "Geometry":            "locn:Geometry",
    "address":             { "@id": "locn:address", "@type": "@id" },
    "fullAddress":         "locn:fullAddress",
    "postCode":            "locn:postCode",
    "postName":            "locn:postName",
    "thoroughfare":        "locn:thoroughfare",
    "locatorDesignator":   "locn:locatorDesignator",
    "locatorName":         "locn:locatorName",
    "addressArea":         "locn:addressArea",
    "addressId":           "locn:addressId",
    "adminUnitL1":         "locn:adminUnitL1",
    "adminUnitL2":         "locn:adminUnitL2",
    "poBox":               "locn:poBox",
    "geographicName":      "locn:geographicName",
    "geometry":            { "@id": "locn:geometry", "@type": "@id" },

    "PublicEvent":         "cv:PublicEvent",
    "eventStatus":         "cv:eventStatus",
    "mainOrganiser":       { "@id": "cv:mainOrganiser", "@type": "@id" },

    "PublicService":       "cpsv:PublicService",
    "Channel":             "cv:Channel",
    "Cost":                "cv:Cost",
    "Output":              "cv:Output",
    "Rule":                "cpsv:Rule",
    "implements":          { "@id": "cpsv:implements", "@type": "@id" },

    "Identifier":          "adms:Identifier",
    "Asset":               "adms:Asset",
    "AssetDistribution":   "adms:AssetDistribution",
    "schemaAgency":        "adms:schemaAgency",
    "notation":            "skos:notation",
    "identifier":          { "@id": "adms:identifier", "@type": "@id", "@container": "@set" },

    "prefLabel":           "skos:prefLabel",
    "altLabel":            "skos:altLabel",
    "description":         "dcterms:description",
    "issued":              { "@id": "dcterms:issued", "@type": "xsd:date" },
    "conformsTo":          { "@id": "dcterms:conformsTo", "@type": "@id" },
    "spatial":             { "@id": "dcterms:spatial", "@type": "@id" },
    "classification":      { "@id": "org:classification", "@type": "@id" },
    "purpose":             { "@id": "org:purpose", "@type": "@id" },
    "originalOrganization": { "@id": "org:originalOrganization", "@type": "@id" },
    "resultingOrganization": { "@id": "org:resultingOrganization", "@type": "@id" }
  }
}
