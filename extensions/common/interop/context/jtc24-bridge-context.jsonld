{
  "_comment": "CEN/CENELEC JTC 24 bridge context: maps JTC 24 terminology to OpenEPCIS vocabulary. Covers EN 18216, 18219, 18220, 18221, 18222, 18223 (FprEN stage, publishing March 2026) and prEN 18239, prEN 18246 (in development). Property names for the six finalised standards reflect the FprEN text; in-development standards (18239, 18246) remain draft-aligned and will be updated on publication.",
  "@context": {
    "@version": 1.1,
    "dpp": "https://ref.openepcis.io/extensions/common/core/",
    "gs1": "https://ref.gs1.org/voc/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "ProductPassport": "dpp:DigitalProductPassport",
    "PassportStatus": "dpp:PassportStatus",

    "passportId": {
      "@id": "dpp:passportIdentifier",
      "@type": "@id"
    },
    "passportStatus": {
      "@id": "dpp:passportStatus",
      "@type": "@vocab",
      "@context": {
        "Draft": "dpp:Draft",
        "Active": "dpp:Active",
        "Updated": "dpp:Active",
        "Withdrawn": "dpp:Withdrawn",
        "Archived": "dpp:Archived"
      }
    },
    "passportVersion": "dpp:passportVersion",
    "passportIssueDate": {
      "@id": "dpp:passportIssueDate",
      "@type": "xsd:date"
    },
    "passportLastModified": {
      "@id": "dpp:lastUpdated",
      "@type": "xsd:dateTime"
    },
    "passportExpiryDate": {
      "@id": "dpp:passportExpiryDate",
      "@type": "xsd:date"
    },
    "passportIssuer": {
      "@id": "dpp:passportIssuer",
      "@type": "@id"
    },
    "previousVersion": {
      "@id": "dpp:previousPassportVersion",
      "@type": "@id"
    },

    "uniqueId": {
      "@id": "gs1:productID",
      "@type": "@id"
    },
    "productId": "gs1:gtin",
    "batchId": "gs1:hasBatchLotNumber",
    "serialId": "gs1:hasSerialNumber",
    "productModel": "schema:ProductModel",
    "productCategory": {
      "@id": "dpp:productCategory",
      "@type": "@vocab"
    },

    "granularityLevel": {
      "@id": "dpp:granularityLevel",
      "@type": "@vocab",
      "@context": {
        "Model": "dpp:Model",
        "Batch": "dpp:Batch",
        "Item": "dpp:Item"
      }
    },

    "manufacturer": {
      "@id": "dpp:operatorInformation",
      "@type": "@id"
    },
    "economicOperatorId": "dpp:economicOperatorId",
    "operatorName": "gs1:organizationName",
    "operatorGln": "gs1:partyGLN",

    "facility": {
      "@id": "dpp:facilityInformation",
      "@type": "@id"
    },
    "facilityGln": "gs1:gln",

    "materialComposition": {
      "@id": "dpp:materialComposition",
      "@type": "@id",
      "@container": "@set"
    },
    "materialName": "schema:name",
    "massFraction": {
      "@id": "dpp:massFraction",
      "@type": "xsd:decimal"
    },

    "substancesOfConcern": {
      "@id": "dpp:substancesOfConcern",
      "@type": "@id",
      "@container": "@set"
    },
    "substanceName": "schema:name",
    "casNumber": "dpp:casNumber",
    "ecNumber": "dpp:ecNumber",
    "concentration": {
      "@id": "dpp:concentration",
      "@type": "xsd:decimal"
    },

    "carbonFootprint": {
      "@id": "dpp:carbonFootprintTotal",
      "@type": "xsd:decimal"
    },
    "declaredUnit": "dpp:declaredUnit",
    "operationalScope": {
      "@id": "dpp:operationalScope",
      "@type": "@vocab",
      "@context": {
        "CradleToGate": "dpp:CradleToGate",
        "CradleToGrave": "dpp:CradleToGrave"
      }
    },

    "recycledContent": {
      "@id": "dpp:recycledContent",
      "@type": "xsd:decimal"
    },
    "recyclableContent": {
      "@id": "dpp:recyclableContent",
      "@type": "xsd:decimal"
    },

    "repairabilityScore": {
      "@id": "dpp:repairabilityScore",
      "@type": "xsd:decimal"
    },
    "repairabilityClass": "dpp:repairabilityClass",
    "expectedLifespan": "dpp:expectedLifespan",
    "guaranteedLifespan": "dpp:guaranteedLifespan",

    "accessLevel": {
      "@id": "dpp:accessLevel",
      "@type": "@vocab",
      "@context": {
        "Public": "dpp:Public",
        "AuthorizedOnly": "dpp:AuthorizedOnly",
        "Restricted": "dpp:Restricted"
      }
    },

    "did": {
      "@id": "dpp:did",
      "@type": "@id"
    },
    "identityCredential": {
      "@id": "dpp:identityCredentialUrl",
      "@type": "@id"
    }
  }
}
