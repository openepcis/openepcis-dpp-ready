{
  "_comment": "CEN/CENELEC JTC 24 bridge context: maps JTC 24 terminology to OpenEPCIS vocabulary. Covers EN 18216, 18219, 18220, 18221, 18222, 18223 (FprEN stage, publishing March 2026) and prEN 18239, prEN 18246 (in development). Property names for the six finalised standards reflect the FprEN text; in-development standards (18239, 18246) remain draft-aligned and will be updated on publication.",
  "@context": {
    "@version": 1.1,
    "oec": "https://ref.openepcis.io/extensions/common/core/",
    "gs1": "https://ref.gs1.org/voc/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "ProductPassport": "oec:DigitalProductPassport",
    "PassportStatus": "oec:PassportStatus",

    "passportId": {
      "@id": "oec:passportIdentifier",
      "@type": "@id"
    },
    "passportStatus": {
      "@id": "oec:passportStatus",
      "@type": "@vocab",
      "@context": {
        "Draft": "oec:Draft",
        "Active": "oec:Active",
        "Updated": "oec:Active",
        "Withdrawn": "oec:Withdrawn",
        "Archived": "oec:Archived"
      }
    },
    "passportVersion": "oec:passportVersion",
    "passportIssueDate": {
      "@id": "oec:passportIssueDate",
      "@type": "xsd:date"
    },
    "passportLastModified": {
      "@id": "oec:lastUpdated",
      "@type": "xsd:dateTime"
    },
    "passportExpiryDate": {
      "@id": "oec:passportExpiryDate",
      "@type": "xsd:date"
    },
    "passportIssuer": {
      "@id": "oec:passportIssuer",
      "@type": "@id"
    },
    "previousVersion": {
      "@id": "oec:previousPassportVersion",
      "@type": "@id"
    },

    "uniqueId": {
      "@id": "gs1:productID",
      "@type": "@id"
    },
    "productId": "gs1:gtin",
    "batchId": "gs1:hasBatchLotNumber",
    "serialId": "gs1:hasSerialNumber",
    "productModel": "schema:ProductModel",
    "productCategory": {
      "@id": "oec:productCategory",
      "@type": "@vocab"
    },

    "granularityLevel": {
      "@id": "oec:granularityLevel",
      "@type": "@vocab",
      "@context": {
        "Model": "oec:Model",
        "Batch": "oec:Batch",
        "Item": "oec:Item"
      }
    },

    "manufacturer": {
      "@id": "oec:operatorInformation",
      "@type": "@id"
    },
    "economicOperatorId": "oec:economicOperatorId",
    "operatorName": "gs1:organizationName",
    "operatorGln": "gs1:partyGLN",

    "facility": {
      "@id": "oec:facilityInformation",
      "@type": "@id"
    },
    "facilityGln": "gs1:gln",

    "materialComposition": {
      "@id": "oec:materialComposition",
      "@type": "@id",
      "@container": "@set"
    },
    "materialName": "schema:name",
    "massFraction": {
      "@id": "oec:massFraction",
      "@type": "xsd:decimal"
    },

    "substancesOfConcern": {
      "@id": "oec:substancesOfConcern",
      "@type": "@id",
      "@container": "@set"
    },
    "substanceName": "schema:name",
    "casNumber": "oec:casNumber",
    "ecNumber": "oec:ecNumber",
    "concentration": {
      "@id": "oec:concentration",
      "@type": "xsd:decimal"
    },

    "carbonFootprint": {
      "@id": "oec:carbonFootprintTotal",
      "@type": "xsd:decimal"
    },
    "declaredUnit": "oec:declaredUnit",
    "operationalScope": {
      "@id": "oec:operationalScope",
      "@type": "@vocab",
      "@context": {
        "CradleToGate": "oec:CradleToGate",
        "CradleToGrave": "oec:CradleToGrave"
      }
    },

    "recycledContent": {
      "@id": "oec:recycledContent",
      "@type": "xsd:decimal"
    },
    "recyclableContent": {
      "@id": "oec:recyclableContent",
      "@type": "xsd:decimal"
    },

    "repairabilityScore": {
      "@id": "oec:repairabilityScore",
      "@type": "xsd:decimal"
    },
    "repairabilityClass": "oec:repairabilityClass",
    "expectedLifespan": "oec:expectedLifespan",
    "guaranteedLifespan": "oec:guaranteedLifespan",

    "accessLevel": {
      "@id": "oec:accessLevel",
      "@type": "@vocab",
      "@context": {
        "Public": "oec:Public",
        "AuthorizedOnly": "oec:AuthorizedOnly",
        "Restricted": "oec:Restricted"
      }
    },

    "did": {
      "@id": "oec:did",
      "@type": "@id"
    },
    "identityCredential": {
      "@id": "oec:identityCredentialUrl",
      "@type": "@id"
    }
  }
}
