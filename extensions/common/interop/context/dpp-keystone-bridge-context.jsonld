{
  "@context": {
    "@version": 1.1,
    "dppk": "https://dpp-keystone.org/spec/v2/terms#",
    "oec": "https://ref.openepcis.io/extensions/common/core/",
    "eusteel": "https://ref.openepcis.io/extensions/eu/iron-steel/",
    "eutex": "https://ref.openepcis.io/extensions/eu/textile/",
    "eucpr": "https://ref.openepcis.io/extensions/eu/cpr/",
    "gs1": "https://ref.gs1.org/voc/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Product": "gs1:Product",
    "Organization": "oec:OperatorInformation",
    "Component": "oec:MaterialComposition",

    "gtin": "gs1:gtin",
    "productName": "gs1:productName",
    "brand": "gs1:brandName",
    "model": "schema:model",
    "netWeight": "gs1:netWeight",
    "countryOfOrigin": "gs1:countryOfOrigin",

    "economicOperatorId": "oec:economicOperatorId",
    "facilityId": "oec:facilityId",
    "organizationName": "gs1:organizationName",
    "gln": "gs1:globalLocationNumber",
    "manufacturer": {"@id": "gs1:manufacturer", "@type": "@id"},

    "componentName": "oec:componentName",
    "componentIdentifier": "oec:componentIdentifier",
    "componentCasNumber": "oec:casNumber",
    "componentEcNumber": "oec:ecNumber",
    "componentIupacName": "oec:iupacName",
    "componentLocationInProduct": "oec:substanceLocation",
    "componentPercentage": {"@id": "oec:massFraction", "@type": "xsd:decimal"},

    "IronSteelProduct": "eusteel:IronSteelProduct",
    "heatNumber": "eusteel:heatNumber",
    "castNumber": "eusteel:castNumber",
    "lotNumber": "eusteel:lotNumber",
    "productNumber": "eusteel:productNumber",
    "purchaserOrder": "eusteel:purchaserOrder",
    "steelGradeClassification": "eusteel:steelGradeClassification",
    "steelDesignation": "eusteel:steelDesignation",
    "technologyRoute": "eusteel:technologyRoute",
    "meltAndPourCountry": "eusteel:meltAndPourCountry",
    "cbamReportId": "eusteel:cbamReportId",

    "MaterialTestCertificate": "eusteel:MaterialTestCertificate",
    "mtc": {"@id": "eusteel:mtc", "@type": "@id"},
    "mtcNominalSize": {"@id": "eusteel:mtcNominalSize", "@type": "xsd:decimal"},
    "mtcWeightTolerance": {"@id": "eusteel:mtcWeightTolerance", "@type": "xsd:decimal"},
    "mtcYieldStrength": {"@id": "eusteel:mtcYieldStrength", "@type": "xsd:decimal"},
    "mtcYieldStrengthRatio": {"@id": "eusteel:mtcYieldStrengthRatio", "@type": "xsd:decimal"},
    "mtcElongation": {"@id": "eusteel:mtcElongation", "@type": "xsd:decimal"},
    "mtcRelativeRibArea": {"@id": "eusteel:mtcRelativeRibArea", "@type": "xsd:decimal"},
    "mtcCarbonContent": {"@id": "eusteel:mtcCarbonContent", "@type": "xsd:decimal"},
    "mtcPhosphorusContent": {"@id": "eusteel:mtcPhosphorusContent", "@type": "xsd:decimal"},
    "mtcSulfurContent": {"@id": "eusteel:mtcSulfurContent", "@type": "xsd:decimal"},
    "mtcCopperContent": {"@id": "eusteel:mtcCopperContent", "@type": "xsd:decimal"},
    "mtcNitrogenContent": {"@id": "eusteel:mtcNitrogenContent", "@type": "xsd:decimal"},
    "mtcCarbonEquivalent": {"@id": "eusteel:mtcCarbonEquivalent", "@type": "xsd:decimal"},
    "mtcSteelProcess": "eusteel:mtcSteelProcess",
    "mtcFinishing": "eusteel:mtcFinishing",
    "mtcRadiometricControl": {"@id": "eusteel:mtcRadiometricControl", "@type": "xsd:decimal"},

    "EPDBlock": "oec:EnvironmentalProductDeclaration",
    "ImpactValues": "oec:ImpactIndicatorResult",
    "epd": {"@id": "oec:environmentalProductDeclaration", "@type": "@id"},
    "indicator": {"@id": "oec:impactIndicator", "@type": "@id"},

    "DoPCBlock": "eucpr:DeclarationOfPerformance",
    "DeclarationOfPerformance": "eucpr:DeclarationOfPerformance",
    "ConstructionProduct": "eucpr:ConstructionProduct",
    "dopc": {"@id": "eucpr:declarationOfPerformance", "@type": "@id"},
    "hasDoP": {"@id": "eucpr:declarationOfPerformance", "@type": "@id"},
    "declarationCode": "eucpr:declarationCode",
    "dopIdentifier": "eucpr:declarationCode",
    "dateOfIssue": {"@id": "eucpr:dateOfIssue", "@type": "xsd:date"},
    "harmonisedStandardReference": {"@id": "eucpr:harmonisedStandard", "@type": "xsd:anyURI"},
    "avsSystem": "eucpr:avcpSystem",
    "notifiedBody": {"@id": "eucpr:notifiedBody", "@type": "@id"},
    "technicalAssessmentBody": {"@id": "eucpr:technicalAssessmentBody", "@type": "@id"},
    "validationReports": {"@id": "eucpr:validationReports", "@type": "@id"},
    "europeanAssessmentDocument": {"@id": "eucpr:europeanAssessmentDocument", "@type": "@id"},
    "thermalConductivity": {"@id": "eucpr:thermalConductivity", "@type": "@id"},
    "compressiveStrength": {"@id": "eucpr:compressiveStrength", "@type": "@id"},

    "TextileProduct": "gs1:Product",
    "euDeclarationOfConformity": {"@id": "eutex:euDeclarationOfConformity", "@type": "@id"},
    "robustnessScore": {"@id": "eutex:robustnessScore", "@type": "xsd:decimal"},
    "recyclabilityScore": {"@id": "eutex:recyclabilityScore", "@type": "xsd:decimal"},
    "carbonFootprint": {"@id": "eutex:carbonFootprintManufacturing", "@type": "xsd:decimal"},
    "carbonFootprintClass": {"@id": "eutex:carbonFootprintClass", "@type": "xsd:integer"},
    "environmentalFootprint": {"@id": "eutex:pefSingleScore", "@type": "xsd:decimal"},
    "environmentalFootprintClass": {"@id": "eutex:environmentalFootprintClass", "@type": "xsd:integer"},
    "carbonFootprintBenchmarkPercentage": {"@id": "eutex:benchmarkPerformance", "@type": "xsd:decimal"},
    "environmentalFootprintBenchmarkPercentage": {"@id": "eutex:benchmarkPerformance", "@type": "xsd:decimal"},
    "textileWeight": {"@id": "gs1:netWeight", "@type": "@id"},
    "weightExcludingTrims": {"@id": "eutex:weightExcludingTrims", "@type": "xsd:decimal"},
    "animalOriginNonTextile": {"@id": "eutex:containsAnimalNonTextileParts", "@type": "xsd:boolean"},
    "euEcolabel": {"@id": "eutex:euEcolabel", "@type": "xsd:boolean"},
    "organicContentPercentage": {"@id": "eutex:organicContentPercentage", "@type": "xsd:decimal"},
    "organicContentMass": {"@id": "eutex:organicContentMass", "@type": "xsd:decimal"},
    "preConsumerRecycledContentPercentage": {"@id": "oec:preConsumerRecycledContent", "@type": "xsd:decimal"},
    "postConsumerRecycledContentPercentage": {"@id": "oec:postConsumerRecycledContent", "@type": "xsd:decimal"},
    "textileSubstancesOfConcern": {"@id": "oec:substancesOfConcern", "@type": "@id"},
    "textileCareInstructions": {"@id": "eutex:careInstructions", "@type": "@id"}
  }
}
