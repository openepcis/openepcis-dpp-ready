{
  "_comment": "OpenEPCIS CPR Vocabulary v0.1.0, EU Construction Products Regulation 2024/3110. Module is intentionally thin; nearly every cross-cutting CPR data point reuses the lifted oec: vocabulary plus untp: and gs1:. Only construction-specific terms (ConstructionProduct, declarationOfPerformanceUrl, essentialCharacteristic, reactionToFireClass, constructionProductType) live in the eucpr: namespace.",
  "@context": [
    "https://ref.openepcis.io/extensions/common/core/dpp-core-context.jsonld",
    {
      "@version": 1.1,
      "eucpr": "https://ref.openepcis.io/extensions/eu/cpr/",
      "oec": "https://ref.openepcis.io/extensions/common/core/",
      "gs1": "https://ref.gs1.org/voc/",
      "schema": "https://schema.org/",
      "xsd": "http://www.w3.org/2001/XMLSchema#",
      "id": "@id",
      "type": "@type",
      "manufacturer": {
        "@id": "gs1:manufacturer",
        "@type": "@id"
      },
      "regulatoryInformation": {
        "@id": "gs1:regulatoryInformation",
        "@type": "@id",
        "@container": "@set"
      },
      "RegulatoryInformation": "gs1:RegulatoryInformation",
      "regulationType": {
        "@id": "gs1:regulationType",
        "@type": "@id"
      },
      "regulatoryAct": "gs1:regulatoryAct",
      "isRegulationCompliant": {
        "@id": "oec:isRegulationCompliant",
        "@type": "xsd:boolean"
      },
      "ConstructionProduct": "eucpr:ConstructionProduct",
      "constructionProductType": {
        "@id": "eucpr:constructionProductType",
        "@type": "@vocab",
        "@context": {
          "Cement": "eucpr:Cement",
          "Aggregate": "eucpr:Aggregate",
          "Insulation": "eucpr:Insulation",
          "WindowAndDoor": "eucpr:WindowAndDoor",
          "Membrane": "eucpr:Membrane",
          "StructuralTimber": "eucpr:StructuralTimber",
          "Reinforcement": "eucpr:Reinforcement",
          "Mortar": "eucpr:Mortar",
          "Concrete": "eucpr:Concrete",
          "CladdingPanel": "eucpr:CladdingPanel",
          "OtherConstructionProduct": "eucpr:OtherConstructionProduct"
        }
      },
      "reactionToFireClass": {
        "@id": "eucpr:reactionToFireClass",
        "@type": "@vocab",
        "@context": {
          "A1": "eucpr:FireClassA1",
          "A2": "eucpr:FireClassA2",
          "B": "eucpr:FireClassB",
          "C": "eucpr:FireClassC",
          "D": "eucpr:FireClassD",
          "E": "eucpr:FireClassE",
          "F": "eucpr:FireClassF"
        }
      },
      "declarationOfPerformanceUrl": {
        "@id": "eucpr:declarationOfPerformanceUrl",
        "@type": "xsd:anyURI"
      },
      "EssentialCharacteristic": "eucpr:EssentialCharacteristic",
      "essentialCharacteristic": {
        "@id": "eucpr:essentialCharacteristic",
        "@type": "@id",
        "@container": "@set"
      },
      "characteristicName": "eucpr:characteristicName",
      "characteristicValue": {
        "@id": "eucpr:characteristicValue",
        "@type": "@id"
      },
      "harmonisedStandard": {
        "@id": "eucpr:harmonisedStandard",
        "@type": "xsd:anyURI"
      },
      "thermalConductivity": {
        "@id": "eucpr:thermalConductivity",
        "@type": "@id"
      },
      "compressiveStrength": {
        "@id": "eucpr:compressiveStrength",
        "@type": "@id"
      },
      "DeclarationOfPerformance": "eucpr:DeclarationOfPerformance",
      "declarationOfPerformance": {
        "@id": "eucpr:declarationOfPerformance",
        "@type": "@id"
      },
      "declarationCode": "eucpr:declarationCode",
      "dateOfIssue": {
        "@id": "eucpr:dateOfIssue",
        "@type": "xsd:date"
      },
      "avcpSystem": {
        "@id": "eucpr:avcpSystem",
        "@type": "@vocab",
        "@context": {
          "1+": "eucpr:System1Plus",
          "1": "eucpr:System1",
          "2+": "eucpr:System2Plus",
          "3": "eucpr:System3",
          "4": "eucpr:System4"
        }
      },
      "notifiedBody": {
        "@id": "eucpr:notifiedBody",
        "@type": "@id"
      },
      "technicalAssessmentBody": {
        "@id": "eucpr:technicalAssessmentBody",
        "@type": "@id"
      },
      "europeanAssessmentDocument": {
        "@id": "eucpr:europeanAssessmentDocument",
        "@type": "@id"
      },
      "validationReports": {
        "@id": "eucpr:validationReports",
        "@type": "@id",
        "@container": "@set"
      },
      "AVCPSystem": "eucpr:AVCPSystem",
      "ConstructionProductType": "eucpr:ConstructionProductType",
      "ReactionToFireClass": "eucpr:ReactionToFireClass",
      "QuantitativeValue": "gs1:QuantitativeValue",
      "gs1:manufacturer": {
        "@id": "gs1:manufacturer",
        "@type": "@id"
      },
      "gs1:regulatoryInformation": {
        "@id": "gs1:regulatoryInformation",
        "@type": "@id",
        "@container": "@set"
      },
      "gs1:regulationType": {
        "@id": "gs1:regulationType",
        "@type": "@id"
      },
      "oec:isRegulationCompliant": {
        "@id": "oec:isRegulationCompliant",
        "@type": "xsd:boolean"
      },
      "eucpr:declarationOfPerformanceUrl": {
        "@id": "eucpr:declarationOfPerformanceUrl",
        "@type": "xsd:anyURI"
      },
      "eucpr:essentialCharacteristic": {
        "@id": "eucpr:essentialCharacteristic",
        "@type": "@id",
        "@container": "@set"
      },
      "eucpr:characteristicValue": {
        "@id": "eucpr:characteristicValue",
        "@type": "@id"
      },
      "eucpr:harmonisedStandard": {
        "@id": "eucpr:harmonisedStandard",
        "@type": "xsd:anyURI"
      }
    }
  ]
}
