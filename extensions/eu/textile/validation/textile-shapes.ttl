# Take-Back Program Shape
# -----------------------------------------------------------------------------
eutex:TakeBackProgramShape a sh:NodeShape ;
    sh:targetClass eutex:TakeBackProgram ;
    rdfs:label "Take-Back Program Shape" ;
    sh:property [
        sh:path eutex:takeBackUrl ;
        sh:datatype xsd:anyURI ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path eutex:takeBackIncentive ;
        sh:datatype xsd:string ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path eutex:endOfLifeDestination ;
        sh:datatype xsd:string ;
        sh:maxCount 1
    ] .

# -----------------------------------------------------------------------------
# Repair Service Shape
# -----------------------------------------------------------------------------
eutex:RepairServiceShape a sh:NodeShape ;
    sh:targetClass eutex:RepairService ;
    rdfs:label "Repair Service Shape" .

# -----------------------------------------------------------------------------
# Textile Chemical Shape
# -----------------------------------------------------------------------------
eutex:TextileChemicalShape a sh:NodeShape ;
    sh:targetClass eutex:TextileChemical ;
    rdfs:label "Textile Chemical Shape" ;
    sh:property [
        sh:path schema:name ;
        sh:name "Chemical Name" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path eutex:chemicalPurpose ;
        sh:datatype xsd:string ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path eutex:isMRSLCompliant ;
        sh:datatype xsd:boolean ;
        sh:maxCount 1
    ] .

# =============================================================================
# QuantitativeValue unitCode Shapes (GS1-idiomatic)
# =============================================================================

eutex:WaterUsageShape a sh:NodeShape ;
    sh:targetSubjectsOf eutex:waterUsage ;
    sh:property [
        sh:path ( eutex:waterUsage gs1:unitCode ) ;
        sh:hasValue "LTR" ;
        sh:message "eutex:waterUsage must use unitCode 'LTR' (liters)"@en
    ] .

eutex:EnergyUsageShape a sh:NodeShape ;
    sh:targetSubjectsOf eutex:energyUsage ;
    sh:property [
        sh:path ( eutex:energyUsage gs1:unitCode ) ;
        sh:hasValue "KWH" ;
        sh:message "eutex:energyUsage must use unitCode 'KWH' (kilowatt-hours)"@en
    ] .

eutex:SheddingRateShape a sh:NodeShape ;
    sh:targetSubjectsOf eutex:sheddingRate ;
    sh:property [
        sh:path ( eutex:sheddingRate gs1:unitCode ) ;
        sh:hasValue "MGM" ;
        sh:message "eutex:sheddingRate must use unitCode 'MGM' (mg/kg)"@en
    ] .
