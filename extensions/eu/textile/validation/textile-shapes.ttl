        sh:maxCount 1
    ] ;
    sh:property [
        sh:path eutex:lciaValue ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path eutex:lciaUnit ;
        sh:datatype xsd:string ;
        sh:maxCount 1
    ] .

