@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# BatteryPass Consortium SAMM property reference (github.com/batterypass, CC-BY-4.0).
# Derived browsable copy of the preferredName/description of the SAMM properties our
# battery ontology aligns to. Generated by scripts/build-batterypass-samm-terms.ts.

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#CarbonFootprintPerLifecycleStageEntity>
    a rdf:Property ;
    rdfs:label "Carbon Footprint Per Lifecycle Stage Entity"@en ;
    rdfs:comment "The carbon footprint of the battery as share of total Battery Carbon Footprint, differentiated per life cycle stage raw material extraction, main production, distribution and end of life and recycling."@en ;
    skos:definition "The carbon footprint of the battery as share of total Battery Carbon Footprint, differentiated per life cycle stage raw material extraction, main production, distribution and end of life and recycling."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#absoluteCarbonFootprint>
    a rdf:Property ;
    rdfs:label "Absolute Carbon Footprint"@en ;
    rdfs:comment "As a non-mandatory data attribute, the battery passport should include the battery carbon footprint in absolute terms.\n\nThe absolute battery carbon footprint should be calculated as kilograms of carbon dioxide equivalent, without reference to the functional unit as prescribed by the battery regulation.\n\nDIN DKE Spec 99100 chapter reference: 6.3.10"@en ;
    skos:definition "As a non-mandatory data attribute, the battery passport should include the battery carbon footprint in absolute terms.\n\nThe absolute battery carbon footprint should be calculated as kilograms of carbon dioxide equivalent, without reference to the functional unit as prescribed by the battery regulation.\n\nDIN DKE Spec 99100 chapter reference: 6.3.10"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#batteryCarbonFootprint>
    a rdf:Property ;
    rdfs:label "Battery Carbon Footprint"@en ;
    rdfs:comment "The carbon footprint of the battery, calculated as kg of carbon dioxide equivalent per one kWh of the total energy provided by the battery over its expected service life, as declared in the Carbon Footprint Declaration.\nDIN DKE Spec 99100 chapter reference: 6.3.2"@en ;
    skos:definition "The carbon footprint of the battery, calculated as kg of carbon dioxide equivalent per one kWh of the total energy provided by the battery over its expected service life, as declared in the Carbon Footprint Declaration.\nDIN DKE Spec 99100 chapter reference: 6.3.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#carbonFootprint>
    a rdf:Property ;
    rdfs:label "Carbon Footprint"@en ;
    rdfs:comment "Carbon footprint of the individual lifecycle stage"@en ;
    skos:definition "Carbon footprint of the individual lifecycle stage"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#carbonFootprintPerLifecycleStage>
    a rdf:Property ;
    rdfs:label "Carbon Footprint Per Lifecycle Stage"@en ;
    rdfs:comment "The carbon footprint of the battery as share of total Battery Carbon Footprint, differentiated per life cycle stages raw material extraction, battery production, distribution and recycling.\n\nDIN DKE Spec 99100 chapter reference: \n6.3.3: Raw material extraction\n6.3.4: Main production\n6.3.5: Distrinution\n6.3.6: EoL/Recycling"@en ;
    skos:definition "The carbon footprint of the battery as share of total Battery Carbon Footprint, differentiated per life cycle stages raw material extraction, battery production, distribution and recycling.\n\nDIN DKE Spec 99100 chapter reference: \n6.3.3: Raw material extraction\n6.3.4: Main production\n6.3.5: Distrinution\n6.3.6: EoL/Recycling"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#carbonFootprintPerformanceClass>
    a rdf:Property ;
    rdfs:label "Carbon Footprint Performance Class"@en ;
    rdfs:comment "The carbon footprint performance class that the relevant battery model per manufacturing plant corresponds to.\n\nDIN DKE Spec 99100 chapter reference:  6.3.7"@en ;
    skos:definition "The carbon footprint performance class that the relevant battery model per manufacturing plant corresponds to.\n\nDIN DKE Spec 99100 chapter reference:  6.3.7"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#carbonFootprintStudy>
    a rdf:Property ;
    rdfs:label "Carbon Footprint Study"@en ;
    rdfs:comment "A web link to get access to a public version of the study supporting the carbon footprint values.\n\nDIN DKE Spec 99100 chapter reference:  6.3.8"@en ;
    skos:definition "A web link to get access to a public version of the study supporting the carbon footprint values.\n\nDIN DKE Spec 99100 chapter reference:  6.3.8"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.CarbonFootprint:1.2.0#lifecycleStage>
    a rdf:Property ;
    rdfs:label "Lifecycle Stage"@en ;
    rdfs:comment "The description of the life cycle stage"@en ;
    skos:definition "The description of the life cycle stage"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#DismantlingAndRemovalDocumentation>
    a rdf:Property ;
    rdfs:label "dismantling and removal documentation"@en ;
    rdfs:comment "Dismantling and Removal information, including at least:- Exploded diagrams of the battery system/pack showing the location of battery cells- Disassembly sequences- Type and number of fastening techniques to be unlocked- Tools required for disassembly- Warnings if risk of damaging parts exists- Amount of cells used and layoutEUBR: Annex XIII (2c)"@en ;
    skos:definition "Dismantling and Removal information, including at least:- Exploded diagrams of the battery system/pack showing the location of battery cells- Disassembly sequences- Type and number of fastening techniques to be unlocked- Tools required for disassembly- Warnings if risk of damaging parts exists- Amount of cells used and layoutEUBR: Annex XIII (2c)"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#RecycledContentEntity>
    a rdf:Property ;
    rdfs:label "recycled content"@en ;
    rdfs:comment "A battery passport must include recycled content information.\n\nThe content information must include the percentage share of nickel that is present in active materials and that has been recovered from battery manufacturing waste, for each battery model per year and per manufacturing plant."@en ;
    skos:definition "A battery passport must include recycled content information.\n\nThe content information must include the percentage share of nickel that is present in active materials and that has been recovered from battery manufacturing waste, for each battery model per year and per manufacturing plant."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#dismantlingAndRemovalInformation>
    a rdf:Property ;
    rdfs:label "dismantling and removal information"@en ;
    rdfs:comment "Dismantling and Removal information, including at least:- Exploded diagrams of the battery system/pack showing the location of battery cells- Disassembly sequences- Type and number of fastening techniques to be unlocked- Tools required for disassembly- Warnings if risk of damaging parts exists- Amount of cells used and layout. BR Annex XIII (2c)\n\nDIN DKE Spec 99100 chapter reference: 6.6.1.2"@en ;
    skos:definition "Dismantling and Removal information, including at least:- Exploded diagrams of the battery system/pack showing the location of battery cells- Disassembly sequences- Type and number of fastening techniques to be unlocked- Tools required for disassembly- Warnings if risk of damaging parts exists- Amount of cells used and layout. BR Annex XIII (2c)\n\nDIN DKE Spec 99100 chapter reference: 6.6.1.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#documentType>
    a rdf:Property ;
    rdfs:label "document type"@en ;
    rdfs:comment "Describes type for document e.g. Dismantling manual"@en ;
    skos:definition "Describes type for document e.g. Dismantling manual"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#documentURL>
    a rdf:Property ;
    rdfs:label "document URL"@en ;
    rdfs:comment "Link to document"@en ;
    skos:definition "Link to document"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#emailAddressOfSupplier>
    a rdf:Property ;
    rdfs:label "e-mail address of supplier"@en ;
    rdfs:comment "E-mail address of supplier for spare parts."@en ;
    skos:definition "E-mail address of supplier for spare parts."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#endOfLifeInformation>
    a rdf:Property ;
    rdfs:label "end of life information"@en ;
    rdfs:comment "Producer or producer responsibility organisations shall make information available to distributors and end-users on: the role of end-users in contributing to waste prevention, including by information on good practices and recommendations concerning the use of batteries aiming at extending their use phase and the possibilities of re-use, preparing for re-use, preparing for repurpose, repurposing and remanufacturing.\n\nDIN DKE Spec 99100 chapter reference: 6.6.3.2 - 6.6.3.4"@en ;
    skos:definition "Producer or producer responsibility organisations shall make information available to distributors and end-users on: the role of end-users in contributing to waste prevention, including by information on good practices and recommendations concerning the use of batteries aiming at extending their use phase and the possibilities of re-use, preparing for re-use, preparing for repurpose, repurposing and remanufacturing.\n\nDIN DKE Spec 99100 chapter reference: 6.6.3.2 - 6.6.3.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#extinguishingAgents>
    a rdf:Property ;
    rdfs:label "extinguishing agents"@en ;
    rdfs:comment "Usable extinguishing agents refering to classes of extinguishers (A, B, C, D, K).EUBR: Annex XIII (1a) ? Annex VI Part A (9)"@en ;
    skos:definition "Usable extinguishing agents refering to classes of extinguishers (A, B, C, D, K).EUBR: Annex XIII (1a) ? Annex VI Part A (9)"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#informationOnCollection>
    a rdf:Property ;
    rdfs:label "information on collection"@en ;
    rdfs:comment "Prevention and management of waste batteries: Point (c) of Article 60(1): information on the separate collection, the take back, the collection points and preparing for re-use, preparing for repurposing, and recycling operations available for waste batteries"@en ;
    skos:definition "Prevention and management of waste batteries: Point (c) of Article 60(1): information on the separate collection, the take back, the collection points and preparing for re-use, preparing for repurposing, and recycling operations available for waste batteries"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#mimeType>
    a rdf:Property ;
    rdfs:label "mime type"@en ;
    rdfs:comment "Defines internet media typ to determin how to interpret the documentURL"@en ;
    skos:definition "Defines internet media typ to determin how to interpret the documentURL"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#nameOfSupplier>
    a rdf:Property ;
    rdfs:label "name of supplier"@en ;
    rdfs:comment "Name of Supplier"@en ;
    skos:definition "Name of Supplier"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#postConsumerShare>
    a rdf:Property ;
    rdfs:label "post consumer share"@en ;
    rdfs:comment "Recycled material share from post-consumer waste (end-of-life scrap) of the active material."@en ;
    skos:definition "Recycled material share from post-consumer waste (end-of-life scrap) of the active material."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#preConsumerShare>
    a rdf:Property ;
    rdfs:label "pre consumer share"@en ;
    rdfs:comment "Recycled material share from pre-consumer waste (manufacturing waste, excluding run-around scrap) of the active material."@en ;
    skos:definition "Recycled material share from pre-consumer waste (manufacturing waste, excluding run-around scrap) of the active material."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#recycledContent>
    a rdf:Property ;
    rdfs:label "recycled content"@en ;
    rdfs:comment "Share of material recovered from waste present in active materials for each battery model per year and per manufacturing plant.\n\nDIN DKE Spec 99100 chapter reference:  6.6.2.3 - 6.6.2.10"@en ;
    skos:definition "Share of material recovered from waste present in active materials for each battery model per year and per manufacturing plant.\n\nDIN DKE Spec 99100 chapter reference:  6.6.2.3 - 6.6.2.10"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#renewableContent>
    a rdf:Property ;
    rdfs:label "renewable content"@en ;
    rdfs:comment "Share of renewable material content. A renewable material is a material made of natural resources that can be replenished. \n\nDIN DKE Spec 99100 chapter reference: 6.6.2.11"@en ;
    skos:definition "Share of renewable material content. A renewable material is a material made of natural resources that can be replenished. \n\nDIN DKE Spec 99100 chapter reference: 6.6.2.11"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#safetyInstructions>
    a rdf:Property ;
    rdfs:label "safety instructions"@en ;
    rdfs:comment "- Safety measures. - Necessary safety instructions to handle waste batteries, including in relation to the risks associated with, and the handling of, batteries containing lithium."@en ;
    skos:definition "- Safety measures. - Necessary safety instructions to handle waste batteries, including in relation to the risks associated with, and the handling of, batteries containing lithium."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#safetyMeasures>
    a rdf:Property ;
    rdfs:label "safety measures"@en ;
    rdfs:comment "Safety measures and instructions should also take past negative and extreme events as well as the separate data attributes ?battery status? and ?battery composition/chemistry? into account.\n\nDIN DKE Spec 99100 chapter reference: 6.6.1.5"@en ;
    skos:definition "Safety measures and instructions should also take past negative and extreme events as well as the separate data attributes ?battery status? and ?battery composition/chemistry? into account.\n\nDIN DKE Spec 99100 chapter reference: 6.6.1.5"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#separateCollection>
    a rdf:Property ;
    rdfs:label "separate collection"@en ;
    rdfs:comment "Prevention and management of waste batteries: Point (b) of Article 60(1): Information on the role of end-users in contributing to the separate collection of waste batteries in accordance with their obligations under Article 51 so as to allow their treatment"@en ;
    skos:definition "Prevention and management of waste batteries: Point (b) of Article 60(1): Information on the role of end-users in contributing to the separate collection of waste batteries in accordance with their obligations under Article 51 so as to allow their treatment"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#sparePartSources>
    a rdf:Property ;
    rdfs:label "spare part sources"@en ;
    rdfs:comment "Contact details of sources for replacement spares. Postal address, including name and brand names, postal code and place, street and number, country, telephone, if any. BR Annex XIII (2b)\n\nDIN DKE Spec 99100 chapter reference: 6.6.1.3"@en ;
    skos:definition "Contact details of sources for replacement spares. Postal address, including name and brand names, postal code and place, street and number, country, telephone, if any. BR Annex XIII (2b)\n\nDIN DKE Spec 99100 chapter reference: 6.6.1.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Circularity:1.2.0#wastePrevention>
    a rdf:Property ;
    rdfs:label "waste prevention"@en ;
    rdfs:comment "Prevention and management of waste batteries: Point (a) of Article 60(1): Information on the role of end-users in contributing to waste prevention, including by information on good practices and recommendations concerning the use of batteries aiming at extending their use phase and the possibilities of re-use, preparing for re-use, preparing for repurpose, repurposing and remanufacturing"@en ;
    skos:definition "Prevention and management of waste batteries: Point (a) of Article 60(1): Information on the role of end-users in contributing to waste prevention, including by information on good practices and recommendations concerning the use of batteries aiming at extending their use phase and the possibilities of re-use, preparing for re-use, preparing for repurpose, repurposing and remanufacturing"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.GeneralProductInformation:1.2.0#batteryMass>
    a rdf:Property ;
    rdfs:label "Battery Mass"@en ;
    rdfs:comment "Mass of the entire battery in kilograms. Voluntary: if the battery is defined on pack or module level: also weight of the modules and/or cells.\n\nDIN DKE Spec chapter reference: 6.1.3.6"@en ;
    skos:definition "Mass of the entire battery in kilograms. Voluntary: if the battery is defined on pack or module level: also weight of the modules and/or cells.\n\nDIN DKE Spec chapter reference: 6.1.3.6"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.GeneralProductInformation:1.2.0#batteryPassportIdentifier>
    a rdf:Property ;
    rdfs:label "BatteryPassportIdentifier"@en ;
    rdfs:comment "Unique identifier allowing for the unambiguous identification of each individual battery and hence each corresponding battery passport (exploration of a potential additional battery passport identifier (not requried per Battery Regulation) ongoing)."@en ;
    skos:definition "Unique identifier allowing for the unambiguous identification of each individual battery and hence each corresponding battery passport (exploration of a potential additional battery passport identifier (not requried per Battery Regulation) ongoing)."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.GeneralProductInformation:1.2.0#manufacturerInformation>
    a rdf:Property ;
    rdfs:label "ManufacturerIdentification"@en ;
    rdfs:comment "Unambiguous identification of the manufacturer of the battery, suggested via a unique operator identifier (as \"unique string of characters for the identification of actors involved in the value chain of products\", ESPR Art. 2(32)). \n\nDIN DKE Spec chapter reference: 6.1.2.4"@en ;
    skos:definition "Unambiguous identification of the manufacturer of the battery, suggested via a unique operator identifier (as \"unique string of characters for the identification of actors involved in the value chain of products\", ESPR Art. 2(32)). \n\nDIN DKE Spec chapter reference: 6.1.2.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.GeneralProductInformation:1.2.0#manufacturingPlace>
    a rdf:Property ;
    rdfs:label "ManufacturingPlace"@en ;
    rdfs:comment "Unambiguous identification of the manufacturing facility (e.g. country, city, street, building (if needed)), suggested via a unique facility identifier (as \"unique string of characters for the identification of locations or buildings involved in the value chain of a product or used by actors involved in the value chain of a product\", ESPR Art. 2(33)).\n\nDIN DKE Spec chapter reference: 6.1.3.1"@en ;
    skos:definition "Unambiguous identification of the manufacturing facility (e.g. country, city, street, building (if needed)), suggested via a unique facility identifier (as \"unique string of characters for the identification of locations or buildings involved in the value chain of a product or used by actors involved in the value chain of a product\", ESPR Art. 2(33)).\n\nDIN DKE Spec chapter reference: 6.1.3.1"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.GeneralProductInformation:1.2.0#operatorInformation>
    a rdf:Property ;
    rdfs:label "OperatorInformation"@en ;
    rdfs:comment "State the name, trade name or mark, postal address, web ad-dress, e-mail address. Suggested reporting via a unique operator identifier (see requirements of unique battery identifier).\n\nDIN DKE Spec chapter reference: 6.1.2.3"@en ;
    skos:definition "State the name, trade name or mark, postal address, web ad-dress, e-mail address. Suggested reporting via a unique operator identifier (see requirements of unique battery identifier).\n\nDIN DKE Spec chapter reference: 6.1.2.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.GeneralProductInformation:1.2.0#productIdentifier>
    a rdf:Property ;
    rdfs:label "ProductIdentifier"@en ;
    rdfs:comment "Unique identifier allowing for the unambiguous identification of each individual battery and hence each corresponding battery passport (exploration of a potential additional battery passport identifier (not requried per Battery Regulation) ongoing).\nDIN DKE Spec chapter reference: 6.1.2.2"@en ;
    skos:definition "Unique identifier allowing for the unambiguous identification of each individual battery and hence each corresponding battery passport (exploration of a potential additional battery passport identifier (not requried per Battery Regulation) ongoing).\nDIN DKE Spec chapter reference: 6.1.2.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.GeneralProductInformation:1.2.0#puttingIntoService>
    a rdf:Property ;
    rdfs:label "Putting Into Service"@en ;
    rdfs:comment "Where appropriate, the battery passport must include information on the date of putting the battery into service. BR Annex VI Part A (1); Art. 3(33); Art. 38(7); ESPR Art. 2(32)\n\nDIN DKE Spec chapter reference: 6.1.3.3"@en ;
    skos:definition "Where appropriate, the battery passport must include information on the date of putting the battery into service. BR Annex VI Part A (1); Art. 3(33); Art. 38(7); ESPR Art. 2(32)\n\nDIN DKE Spec chapter reference: 6.1.3.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Labels:1.2.0#declarationOfConformity>
    a rdf:Property ;
    rdfs:label "Declaration Of Conformity"@en ;
    rdfs:comment "A battery passport must include the EU declaration of conformity.\n\nThe regulation specifies the following requirements regarding the EU declaration of conformity (see BattReg Annex XIII (1r) and BattReg Article 18 (2)):\n\n- The EU declaration of conformity has the model structure set out in Annex IX.\n- The EU declaration of conformity must contain the elements specified in the relevant modules set out in Annex VIII.\n- The EU declaration of conformity must be kept up to date.\n- It is translated into the language or languages required by the Member State in which the battery is placed or made available on the market or put into service.\n- It must be drawn up in electronic format and, where requested, it must be provided in paper format.\n\nDIN DKE Spec chapter reference: 6.2.7"@en ;
    skos:definition "A battery passport must include the EU declaration of conformity.\n\nThe regulation specifies the following requirements regarding the EU declaration of conformity (see BattReg Annex XIII (1r) and BattReg Article 18 (2)):\n\n- The EU declaration of conformity has the model structure set out in Annex IX.\n- The EU declaration of conformity must contain the elements specified in the relevant modules set out in Annex VIII.\n- The EU declaration of conformity must be kept up to date.\n- It is translated into the language or languages required by the Member State in which the battery is placed or made available on the market or put into service.\n- It must be drawn up in electronic format and, where requested, it must be provided in paper format.\n\nDIN DKE Spec chapter reference: 6.2.7"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Labels:1.2.0#labelingMeaning>
    a rdf:Property ;
    rdfs:label "Labeling Meaning"@en ;
    rdfs:comment "Explanation of the meaning of all symbols and labels (including separate collection; cadmium and lead; and carbon footprint and carbon footprint performance class symbols; and symbols and labels printed on batteries or their accompanying documents but not accessible via the battery passport)."@en ;
    skos:definition "Explanation of the meaning of all symbols and labels (including separate collection; cadmium and lead; and carbon footprint and carbon footprint performance class symbols; and symbols and labels printed on batteries or their accompanying documents but not accessible via the battery passport)."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Labels:1.2.0#labelingSubject>
    a rdf:Property ;
    rdfs:label "Labeling Subject"@en ;
    rdfs:comment "Short name of required labeling subjects"@en ;
    skos:definition "Short name of required labeling subjects"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Labels:1.2.0#labels>
    a rdf:Property ;
    rdfs:label "Labels"@en ;
    rdfs:comment "'Separate collection' or 'WEEE label' indicating that a product should not be discarded as unsorted waste but must be sent to separate collection facilities for recovery and recycling. To be printed on the physical label and displayed via the battery passport, suggested to be translated also to text to ensure machine readability.\n\nDIN DKE Spec chapter reference: \n\n6.2.2 Separate collection\n6.2.3 Material symbol for Cadmium and Lead\n6.2.4 Carbon Footprint perfromance class\n6.2.5 Extinguishing agent"@en ;
    skos:definition "'Separate collection' or 'WEEE label' indicating that a product should not be discarded as unsorted waste but must be sent to separate collection facilities for recovery and recycling. To be printed on the physical label and displayed via the battery passport, suggested to be translated also to text to ensure machine readability.\n\nDIN DKE Spec chapter reference: \n\n6.2.2 Separate collection\n6.2.3 Material symbol for Cadmium and Lead\n6.2.4 Carbon Footprint perfromance class\n6.2.5 Extinguishing agent"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Labels:1.2.0#resultOfTestReport>
    a rdf:Property ;
    rdfs:label "Result Of Test Report"@en ;
    rdfs:comment "URL to a document that includes results of tests reports proving compliance in the market conformity assessment procedure with the requirements as per the technical documentation (Art. 7-10, Art. 12-14 and due diligence policies ).\n\nDIN DKE Spec chapter reference 6.2.8"@en ;
    skos:definition "URL to a document that includes results of tests reports proving compliance in the market conformity assessment procedure with the requirements as per the technical documentation (Art. 7-10, Art. 12-14 and due diligence policies ).\n\nDIN DKE Spec chapter reference 6.2.8"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#BatteryMaterialEntity>
    a rdf:Property ;
    rdfs:label "material"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#HazardousSubstanceEntity>
    a rdf:Property ;
    rdfs:label "hazardous substance"@en ;
    rdfs:comment "Hazardous substances (No. 19-23): Name (agreed substance nomenclature, e.g. IUPAC or chemical name) all hazardous substance (as ?any substance that poses a threat to human health and the environment?). Suggested above 0.1 % weight by weight within each (sub-)component."@en ;
    skos:definition "Hazardous substances (No. 19-23): Name (agreed substance nomenclature, e.g. IUPAC or chemical name) all hazardous substance (as ?any substance that poses a threat to human health and the environment?). Suggested above 0.1 % weight by weight within each (sub-)component."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#batteryChemistry>
    a rdf:Property ;
    rdfs:label "product chemistry"@en ;
    rdfs:comment "Composition of a product in general terms by specifying the cathode and anode active material as well as electrolyte.\n\nDIN DKE Spec 99100 chapter reference: 6.5.2"@en ;
    skos:definition "Composition of a product in general terms by specifying the cathode and anode active material as well as electrolyte.\n\nDIN DKE Spec 99100 chapter reference: 6.5.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#batteryMaterialIdentifier>
    a rdf:Property ;
    rdfs:label "identifier"@en ;
    rdfs:comment "CAS Number"@en ;
    skos:definition "CAS Number"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#batteryMaterialLocation>
    a rdf:Property ;
    rdfs:label "location"@en ;
    rdfs:comment "Battery component that relates to the material"@en ;
    skos:definition "Battery component that relates to the material"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#batteryMaterialMass>
    a rdf:Property ;
    rdfs:label "weight"@en ;
    rdfs:comment "Weight of component material"@en ;
    skos:definition "Weight of component material"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#batteryMaterialName>
    a rdf:Property ;
    rdfs:label "name"@en ;
    rdfs:comment "Clear name of Material"@en ;
    skos:definition "Clear name of Material"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#batteryMaterials>
    a rdf:Property ;
    rdfs:label "battery materials"@en ;
    rdfs:comment "\"Component materials used\" (No. 17.a-c): Naming the materials (as a composition of substances) in cathode, anode, electrolyte according to public standards, including specification of the corresponding component (i.e., cathode, anode, or electrolyte). We suggest a reporting threshold of 0.1 % weight by weight.\n\nDIN DKE Spec 99100 chapter reference: 6.5.3-6.5.4"@en ;
    skos:definition "\"Component materials used\" (No. 17.a-c): Naming the materials (as a composition of substances) in cathode, anode, electrolyte according to public standards, including specification of the corresponding component (i.e., cathode, anode, or electrolyte). We suggest a reporting threshold of 0.1 % weight by weight.\n\nDIN DKE Spec 99100 chapter reference: 6.5.3-6.5.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#hazardousSubstanceClass>
    a rdf:Property ;
    rdfs:label "class"@en ;
    rdfs:comment "Battery Regulation narrows reporting to substances falling under defined hazard classes and categories of the CLP regulation."@en ;
    skos:definition "Battery Regulation narrows reporting to substances falling under defined hazard classes and categories of the CLP regulation."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#hazardousSubstanceConcentration>
    a rdf:Property ;
    rdfs:label "concentration"@en ;
    rdfs:comment "Concentration of hazardous substance"@en ;
    skos:definition "Concentration of hazardous substance"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#hazardousSubstanceIdentifier>
    a rdf:Property ;
    rdfs:label "identifier"@en ;
    rdfs:comment "CAS identifier of hazardous substance"@en ;
    skos:definition "CAS identifier of hazardous substance"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#hazardousSubstanceLocation>
    a rdf:Property ;
    rdfs:label "location"@en ;
    rdfs:comment "Hazardous substances (No. 19-23): Location on a (sub-)component-level of all hazardous substances (as ?any substance that poses a threat to human health and the environment?). Suggested via a unique identifier or nomenclature."@en ;
    skos:definition "Hazardous substances (No. 19-23): Location on a (sub-)component-level of all hazardous substances (as ?any substance that poses a threat to human health and the environment?). Suggested via a unique identifier or nomenclature."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.MaterialComposition:1.2.0#hazardousSubstances>
    a rdf:Property ;
    rdfs:label "hazardous substances"@en ;
    rdfs:comment "\"Hazardous substances\" (No 20.a-e): Name (agreed substance nomenclature, e.g. IUPAC or chemical name) all hazardous substance (as ?any substance that poses a threat to human health and the environment?). Suggested above 0.1 % weight by weight within each (sub-)component.\n\nDIN DKE Spec 99100 chapter reference: 6.5.4 - 6.5.6"@en ;
    skos:definition "\"Hazardous substances\" (No 20.a-e): Name (agreed substance nomenclature, e.g. IUPAC or chemical name) all hazardous substance (as ?any substance that poses a threat to human health and the environment?). Suggested above 0.1 % weight by weight within each (sub-)component.\n\nDIN DKE Spec 99100 chapter reference: 6.5.4 - 6.5.6"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#BatteryTechnicalPropertiesEntity>
    a rdf:Property ;
    rdfs:label "Battery Technical Properties Entity"@en ;
    rdfs:comment "Covers all Capability related data attributes"@en ;
    skos:definition "Covers all Capability related data attributes"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#NegativeEventEntity>
    a rdf:Property ;
    rdfs:label "negative event"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#PowerCapabilityAtEntity>
    a rdf:Property ;
    rdfs:label "power capability at"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#batteryTechnicalProperties>
    a rdf:Property ;
    rdfs:label "battery technical properties"@en ;
    rdfs:comment "This property covers all perfromance related properties"@en ;
    skos:definition "This property covers all perfromance related properties"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#cRate>
    a rdf:Property ;
    rdfs:label "C-rate"@en ;
    rdfs:comment "As a non-mandatory data point the battery passport should include the ratio between nominal battery power in W and battery energy in Wh. It aims to provide an indication of the applicable discharge and charge rate in terms of rated capacity (C-rate) (see BattReg Annex IV Part B(2)).\n\nThe update interval should be upon placement on the market and upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.6"@en ;
    skos:definition "As a non-mandatory data point the battery passport should include the ratio between nominal battery power in W and battery energy in Wh. It aims to provide an indication of the applicable discharge and charge rate in terms of rated capacity (C-rate) (see BattReg Annex IV Part B(2)).\n\nThe update interval should be upon placement on the market and upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.6"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#capacityFade>
    a rdf:Property ;
    rdfs:label "capacity fade"@en ;
    rdfs:comment "The capacity fade is the Decrease over time and upon usage in the amount of charge that a battery can deliver at the rated voltage, with respect to the original rated capacity (see BattReg Annex IV (2)) as declared by the manufacturer.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.4"@en ;
    skos:definition "The capacity fade is the Decrease over time and upon usage in the amount of charge that a battery can deliver at the rated voltage, with respect to the original rated capacity (see BattReg Annex IV (2)) as declared by the manufacturer.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#capacityThresholdForExhaustion>
    a rdf:Property ;
    rdfs:label "capacity threshold for exhaustion"@en ;
    rdfs:comment "The percentage of SOCE, above which the battery is still considered operational as EV battery in its current life, as provided by the economic operator.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.9"@en ;
    skos:definition "The percentage of SOCE, above which the battery is still considered operational as EV battery in its current life, as provided by the economic operator.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.9"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#capacityThroughput>
    a rdf:Property ;
    rdfs:label "Capacity Throughput"@en ;
    rdfs:comment "The data attribute should be reported as measured for further potential processing. In addition, the normalisation by capacity may add a further useful value that ensures comparability among battery sizes.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.8"@en ;
    skos:definition "The data attribute should be reported as measured for further potential processing. In addition, the normalisation by capacity may add a further useful value that ensures comparability among battery sizes.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.8"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#capacityThroughputValue>
    a rdf:Property ;
    rdfs:label "capacity throughput"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#currentSelfDischargingRateValue>
    a rdf:Property ;
    rdfs:label "current self discharge rate value"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#energyThroughput>
    a rdf:Property ;
    rdfs:label "Energy Throughput"@en ;
    rdfs:comment "The data attribute should be reported as measured for further potential processing. In addition, the normalisation by capacity may add a further useful value that ensures comparability among battery sizes.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.7"@en ;
    skos:definition "The data attribute should be reported as measured for further potential processing. In addition, the normalisation by capacity may add a further useful value that ensures comparability among battery sizes.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.7"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#energyThroughputValue>
    a rdf:Property ;
    rdfs:label "energy throughput"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#evolutionOfSelfDischarge>
    a rdf:Property ;
    rdfs:label "evolution of self discharge"@en ;
    rdfs:comment "Evolution of self-discharge rates is the change of self-discharge over time and usage, as percentage calculated from the initial and current self-discharge rate.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.8"@en ;
    skos:definition "Evolution of self-discharge rates is the change of self-discharge over time and usage, as percentage calculated from the initial and current self-discharge rate.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.8"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#expectedLifetime>
    a rdf:Property ;
    rdfs:label "expected lifetime"@en ;
    rdfs:comment "The battery passport must include information about the expected battery lifetime in calendar years.\n\nThe update interval must be upon placement on the market and upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.2"@en ;
    skos:definition "The battery passport must include information about the expected battery lifetime in calendar years.\n\nThe update interval must be upon placement on the market and upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#expectedNumberOfCycles>
    a rdf:Property ;
    rdfs:label "expected number of cycles"@en ;
    rdfs:comment "Expected battery lifetime expressed in cycles.\nThe exception for non-cycle applications in Article 10 appears sensible, but is not included in the Annex XIII provision.\nThe data attribute is defined by measurement conditions of the cycle-life test such as the C-Rate (see below) and the depth of discharge in the cycle-life test\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.3"@en ;
    skos:definition "Expected battery lifetime expressed in cycles.\nThe exception for non-cycle applications in Article 10 appears sensible, but is not included in the Annex XIII provision.\nThe data attribute is defined by measurement conditions of the cycle-life test such as the C-Rate (see below) and the depth of discharge in the cycle-life test\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#initialInternalResistance>
    a rdf:Property ;
    rdfs:label "initial internal resistance"@en ;
    rdfs:comment "The battery passport can include additional information about the initial internal resistance on battery module level, if available. It should be defined and calculated analogously as the requirements on battery pack level above.\n\nDIN DKE Spec 99100 chapter reference: 6.7.5.2"@en ;
    skos:definition "The battery passport can include additional information about the initial internal resistance on battery module level, if available. It should be defined and calculated analogously as the requirements on battery pack level above.\n\nDIN DKE Spec 99100 chapter reference: 6.7.5.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#internalResistanceIncrease>
    a rdf:Property ;
    rdfs:label "internal resistance increase"@en ;
    rdfs:comment "The internal resistance increase over time and upon usage should be defined based on the ratio of current and initial values as follows:\nRincrease(x) = (R(x)  - RBOL) / RBOL  100 %\nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.;);\nR(x)\tis the internal resistance at the aging parameter x; and\nRBOL\tis the internal resistance at begin of life.\n\nThe battery passport can include additional information about the internal resistance increase on battery cell and battery module level, if available. It should be defined and calculated analogously to the requirements on battery pack level above.\n\nDIN DKE Spec 99100 chapter reference: 6.7.5.3"@en ;
    skos:definition "The internal resistance increase over time and upon usage should be defined based on the ratio of current and initial values as follows:\nRincrease(x) = (R(x)  - RBOL) / RBOL  100 %\nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.;);\nR(x)\tis the internal resistance at the aging parameter x; and\nRBOL\tis the internal resistance at begin of life.\n\nThe battery passport can include additional information about the internal resistance increase on battery cell and battery module level, if available. It should be defined and calculated analogously to the requirements on battery pack level above.\n\nDIN DKE Spec 99100 chapter reference: 6.7.5.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#lastUpdate>
    a rdf:Property ;
    rdfs:label "last update"@en ;
    rdfs:comment "Timestamp for dynamic data attributes show the last update time."@en ;
    skos:definition "Timestamp for dynamic data attributes show the last update time."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#maximum>
    a rdf:Property ;
    rdfs:label "maximum"@en ;
    rdfs:comment "upper temperature range."@en ;
    skos:definition "upper temperature range."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#maximumVoltage>
    a rdf:Property ;
    rdfs:label "maximum voltage"@en ;
    rdfs:comment "Maximum voltage the battery is rated for.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.10"@en ;
    skos:definition "Maximum voltage the battery is rated for.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.10"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#minimum>
    a rdf:Property ;
    rdfs:label "minimum"@en ;
    rdfs:comment "lower temperature range."@en ;
    skos:definition "lower temperature range."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#negativeEvent>
    a rdf:Property ;
    rdfs:label "negative event"@en ;
    rdfs:comment "Negative event, such as an accident. No further definition provided by regulation."@en ;
    skos:definition "Negative event, such as an accident. No further definition provided by regulation."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#negativeEvents>
    a rdf:Property ;
    rdfs:label "negative events"@en ;
    rdfs:comment "The battery passport must contain information and data resulting from its use such as accidents. \n\nDIN DKE Spec 99100 chapter reference: 6.7.8.4"@en ;
    skos:definition "The battery passport must contain information and data resulting from its use such as accidents. \n\nDIN DKE Spec 99100 chapter reference: 6.7.8.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#nominalVoltage>
    a rdf:Property ;
    rdfs:label "nominal voltag"@en ;
    rdfs:comment "Nominal voltage the battery is rated for.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.11"@en ;
    skos:definition "Nominal voltage the battery is rated for.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.11"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#numberOfFullCycles>
    a rdf:Property ;
    rdfs:label "Number Of Full Cycles"@en ;
    rdfs:comment "Number of (full) charging and discharging cycles.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.4"@en ;
    skos:definition "Number of (full) charging and discharging cycles.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#ohmicResistance>
    a rdf:Property ;
    rdfs:label "resistance"@en ;
    rdfs:comment "Initial (Pre-Use) internal resistance on battery pack level. \n\nDefinition of internal resistance should differ from regulation definition, as \"opposition\" is not an electrotechnical term and may be based on IEV 131-12-04: \"internal resistance means the absolute value of the quotient of the voltage drop between the terminals by the electric current increase in the battery circuit during a current pulse\""@en ;
    skos:definition "Initial (Pre-Use) internal resistance on battery pack level. \n\nDefinition of internal resistance should differ from regulation definition, as \"opposition\" is not an electrotechnical term and may be based on IEV 131-12-04: \"internal resistance means the absolute value of the quotient of the voltage drop between the terminals by the electric current increase in the battery circuit during a current pulse\""@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#originalPowerCapability>
    a rdf:Property ;
    rdfs:label "original power capability"@en ;
    rdfs:comment "Pre-use power capability: Definition of power capability as given in Battery Regulation. \nAnnex IV Part B, point 4 --> measurement at 80 % and 20 % SoC required. This requirement may not be implementable for remaining power capability and power fade(see below). It, thus, should be reviewed together with SoC definition.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.2"@en ;
    skos:definition "Pre-use power capability: Definition of power capability as given in Battery Regulation. \nAnnex IV Part B, point 4 --> measurement at 80 % and 20 % SoC required. This requirement may not be implementable for remaining power capability and power fade(see below). It, thus, should be reviewed together with SoC definition.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#powerCapabilityAt>
    a rdf:Property ;
    rdfs:label "power capability at"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#powerCapabilityRatio>
    a rdf:Property ;
    rdfs:label "power capability ratio"@en ;
    rdfs:comment "Provides information on nominal/recommended charge rate (C-rate); equal to regulation definition."@en ;
    skos:definition "Provides information on nominal/recommended charge rate (C-rate); equal to regulation definition."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#powerFade>
    a rdf:Property ;
    rdfs:label "Power Fade"@en ;
    rdfs:comment "Power fade (in %) means the decrease over time and upon usage in the amount of power that a battery can deliver at the rated voltage. (see BattReg Annex IV (4)).\n\nPower fade should be calculated using original and remaining power capability following the formula below:\nPfade(x) = (1-P(x)) / PBOL\" 100\" %\" \nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.);\nP(x) \tis the power capability at aging parameter x;\nPBOL \tis the power capability at begin of life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.4"@en ;
    skos:definition "Power fade (in %) means the decrease over time and upon usage in the amount of power that a battery can deliver at the rated voltage. (see BattReg Annex IV (4)).\n\nPower fade should be calculated using original and remaining power capability following the formula below:\nPfade(x) = (1-P(x)) / PBOL\" 100\" %\" \nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.);\nP(x) \tis the power capability at aging parameter x;\nPBOL \tis the power capability at begin of life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#ratedCapacity>
    a rdf:Property ;
    rdfs:label "rated capacity"@en ;
    rdfs:comment "Rated capacity is the total number of ampere-hours (Ah) that can be withdrawn from a fully charged battery under reference conditions (see BattReg Annex IV (1)).\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.2"@en ;
    skos:definition "Rated capacity is the total number of ampere-hours (Ah) that can be withdrawn from a fully charged battery under reference conditions (see BattReg Annex IV (1)).\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#ratedEnergy>
    a rdf:Property ;
    rdfs:label "rated energy"@en ;
    rdfs:comment "The certified usable battery energy is the usable battery energy according to the procedure in the UN GTR No 22 as determined during the certification of the vehicle.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.5"@en ;
    skos:definition "The certified usable battery energy is the usable battery energy according to the procedure in the UN GTR No 22 as determined during the certification of the vehicle.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.5"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#ratedMaximumPower>
    a rdf:Property ;
    rdfs:label "rated maximum power"@en ;
    rdfs:comment "This data point describes the value of maximum permitted power the battery is rated for and reflects the data relevant for power limits.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.2"@en ;
    skos:definition "This data point describes the value of maximum permitted power the battery is rated for and reflects the data relevant for power limits.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#remainingCapacity>
    a rdf:Property ;
    rdfs:label "remaining capacity"@en ;
    rdfs:comment "The in-use data attribute on capacity, corresponding with the definition of rated capacity.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.3"@en ;
    skos:definition "The in-use data attribute on capacity, corresponding with the definition of rated capacity.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#remainingEnergy>
    a rdf:Property ;
    rdfs:label "remaining energy"@en ;
    rdfs:comment "Definition from UNECE GTR 22, applicable only to EVs.\nThe energy supplied by the battery from the beginning of the test procedure used for certification until the applicable break-off criterion of the test procedure used for certification is reached.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.6"@en ;
    skos:definition "Definition from UNECE GTR 22, applicable only to EVs.\nThe energy supplied by the battery from the beginning of the test procedure used for certification until the applicable break-off criterion of the test procedure used for certification is reached.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.6"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#remainingPowerCapability>
    a rdf:Property ;
    rdfs:label "remaining power capability"@en ;
    rdfs:comment "'- Original power capability (in Watts) and limits, with temperature range when relevant.\n- The amount of energy that a battery is capable to provide over a given period of time under reference conditions.\n- Power capability at 80% and 20% state of charge.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.3"@en ;
    skos:definition "'- Original power capability (in Watts) and limits, with temperature range when relevant.\n- The amount of energy that a battery is capable to provide over a given period of time under reference conditions.\n- Power capability at 80% and 20% state of charge.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#remainingRoundTripEnergyEfficiency>
    a rdf:Property ;
    rdfs:label "remaining round trip energy efficiency"@en ;
    rdfs:comment "The battery passport shall include information, where possible, about the remaining round trip energy efficiency as information on the state of health of the battery \n\nThe update frequency of remaining round trip energy efficiency should be aligned with the update frequency of round trip energy efficiency fade and should be provided upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.4"@en ;
    skos:definition "The battery passport shall include information, where possible, about the remaining round trip energy efficiency as information on the state of health of the battery \n\nThe update frequency of remaining round trip energy efficiency should be aligned with the update frequency of round trip energy efficiency fade and should be provided upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#remainingRoundTripEnergyEfficiencyValue>
    a rdf:Property ;
    rdfs:label "remaining round trip energy efficiency value"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#roundTripEfficiencyAt50PercentCycleLife>
    a rdf:Property ;
    rdfs:label "round trip efficiency at 50 percent cycle life"@en ;
    rdfs:comment "Initial round trip energy efficiency shall be measured at reference conditions that include the specification of 50 % of cycle-life.\n\nTest methods and reference conditions should separately consider non-cycle applications and batteries with very long cycle-life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.3"@en ;
    skos:definition "Initial round trip energy efficiency shall be measured at reference conditions that include the specification of 50 % of cycle-life.\n\nTest methods and reference conditions should separately consider non-cycle applications and batteries with very long cycle-life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.3"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#roundTripEfficiencyFade>
    a rdf:Property ;
    rdfs:label "Round Trip Efficiency Fade"@en ;
    rdfs:comment "Energy round trip efficiency fade should be calculated using the initial round trip energy efficiency and remaining round trip energy efficiency following the formula below:\n\nRTEfade (x) = (1-RTE(x)) / RTEBOL  100\" %\" \nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.);\nRTE(x) \tis the round trip energy efficiency at aging parameter x;\nRTEBOL \tis the round trip energy efficiency at begin of life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.5"@en ;
    skos:definition "Energy round trip efficiency fade should be calculated using the initial round trip energy efficiency and remaining round trip energy efficiency following the formula below:\n\nRTEfade (x) = (1-RTE(x)) / RTEBOL  100\" %\" \nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.);\nRTE(x) \tis the round trip energy efficiency at aging parameter x;\nRTEBOL \tis the round trip energy efficiency at begin of life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.5"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#roundtripEfficiency>
    a rdf:Property ;
    rdfs:label "round trip efficiency"@en ;
    rdfs:comment "Energy round trip efficiency is the ratio of the net energy delivered by a battery during a discharge test to the total energy required to restore the initial state of charge by a standard charge (see BattReg Annex IV (6)).\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.2"@en ;
    skos:definition "Energy round trip efficiency is the ratio of the net energy delivered by a battery during a discharge test to the total energy required to restore the initial state of charge by a standard charge (see BattReg Annex IV (6)).\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.2"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#stateOfCertifiedEnergy>
    a rdf:Property ;
    rdfs:label "SOCE"@en ;
    rdfs:comment "Definition based on UNECE GTR 22: The measured or on-board UBE performance at a specific point in its lifetime, expressed as a percentage of the certified usable battery energy.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.7"@en ;
    skos:definition "Definition based on UNECE GTR 22: The measured or on-board UBE performance at a specific point in its lifetime, expressed as a percentage of the certified usable battery energy.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.7"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#stateOfCertifiedEnergyValue>
    a rdf:Property ;
    rdfs:label "state of certified energy"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#stateOfCharge>
    a rdf:Property ;
    rdfs:label "SoC"@en ;
    rdfs:comment "The Battery Pass consortium proposes to change the definition to: \"available capacity in a battery expressed as a percentage of remaining capacity\" to reflect use of SoC in practice.  \n\nDIN DKE Spec 99100 chapter reference: 6.7.2.8"@en ;
    skos:definition "The Battery Pass consortium proposes to change the definition to: \"available capacity in a battery expressed as a percentage of remaining capacity\" to reflect use of SoC in practice.  \n\nDIN DKE Spec 99100 chapter reference: 6.7.2.8"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#temperatureInformation>
    a rdf:Property ;
    rdfs:label "temperature information"@en ;
    rdfs:comment "The battery passport must include periodically recorded information on the operating environmental conditions, including temperature.\n\nDIN DKE Spec 99100 chapter reference: 6.7.7.5 - 8"@en ;
    skos:definition "The battery passport must include periodically recorded information on the operating environmental conditions, including temperature.\n\nDIN DKE Spec 99100 chapter reference: 6.7.7.5 - 8"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#temperatureRangeIdleState>
    a rdf:Property ;
    rdfs:label "temperature range idle state"@en ;
    rdfs:comment "Upper an lower boundary of the surrounding temperature range, which the battery can safely withstand. \n\nDIN DKE Spec 99100 chapter reference: 6.7.6.3-4"@en ;
    skos:definition "Upper an lower boundary of the surrounding temperature range, which the battery can safely withstand. \n\nDIN DKE Spec 99100 chapter reference: 6.7.6.3-4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#timeExtremeHighTemp>
    a rdf:Property ;
    rdfs:label "time extreme high temperature"@en ;
    rdfs:comment "Cumulated time spent above the given upper boundary of temperature."@en ;
    skos:definition "Cumulated time spent above the given upper boundary of temperature."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#timeExtremeHighTempCharging>
    a rdf:Property ;
    rdfs:label "time extreme high temperature charging"@en ;
    rdfs:comment "Cumulated time spent above the given upper boundary of temperature during Charging."@en ;
    skos:definition "Cumulated time spent above the given upper boundary of temperature during Charging."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#timeExtremeLowTemp>
    a rdf:Property ;
    rdfs:label "time extreme low temperature"@en ;
    rdfs:comment "Cumulated time spent below the given lower boundary of temperature."@en ;
    skos:definition "Cumulated time spent below the given lower boundary of temperature."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.Performance:1.2.1#timeExtremeLowTempCharging>
    a rdf:Property ;
    rdfs:label "time extreme low temperature charging"@en ;
    rdfs:comment "Cumulated time spent below the given lower boundary of temperature during charging."@en ;
    skos:definition "Cumulated time spent below the given lower boundary of temperature during charging."@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

<urn:samm:io.BatteryPass.SupplyChainDueDiligence:1.2.0#supplyChainIndicies>
    a rdf:Property ;
    rdfs:label "Supply Chain Indicies"@en ;
    rdfs:comment "As a non-mandatory data attribute the battery passport should contain supply chain indices to allow easy assessment for consumers on level of responsible sourcing. ESGE+ indices under development by the GBA (Global Battery Alliance), scoring and benchmarking sustainability performance. Once developed, explore how to best make the indices available via the battery passport.\n\nDIN DKE Spec 99100 chapter reference: 6.4.4"@en ;
    skos:definition "As a non-mandatory data attribute the battery passport should contain supply chain indices to allow easy assessment for consumers on level of responsible sourcing. ESGE+ indices under development by the GBA (Global Battery Alliance), scoring and benchmarking sustainability performance. Once developed, explore how to best make the indices available via the battery passport.\n\nDIN DKE Spec 99100 chapter reference: 6.4.4"@en ;
    dcterms:source <https://github.com/batterypass/BatteryPassDataModel> .

