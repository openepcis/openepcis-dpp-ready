<https://ref.openepcis.io/vocab/batterypass-ready/1.3#BatteryStatus>
    a rdf:Property ;
    rdfs:label "Battery Status"@en ;
    rdfs:comment "Lifecycle status of the battery. Status defined from a list, with the options suggested as follows: 'original', 'repurposed', 'reused', 'remanufactured', 'waste'.\n\nDIN DKE Spec chapter reference: 6.1.3.7"@en ;
    skos:definition "Lifecycle status of the battery. Status defined from a list, with the options suggested as follows: 'original', 'repurposed', 'reused', 'remanufactured', 'waste'.\n\nDIN DKE Spec chapter reference: 6.1.3.7"@en ;
    skos:note "GEFEG BatteryPass-Ready longlist v1.3 attribute (group IdentifiersAndProductData). Definition sourced from the corresponding BatteryPass Consortium SAMM property (io.BatteryPass.*), which the longlist derives from."@en ;
    rdfs:isDefinedBy <https://ref.openepcis.io/vocab/batterypass-ready/1.3> ;
    dcterms:source <https://thebatterypass.eu/battery-pass-ready/publications/> .

