<https://ref.openepcis.io/vocab/batterypass-ready/1.3>
    a owl:Ontology ;
    dcterms:title "GEFEG BatteryPass-Ready attribute vocabulary (longlist v1.3)"@en ;
    dcterms:description "OpenEPCIS-hosted RDF reference for the GEFEG BatteryPass-Ready v1.3 attribute longlist (thebatterypass.eu / batterypass-ready.gefeg.com). GEFEG publishes no RDF IRIs; this vocabulary mirrors the attribute set so it can be aligned with OpenEPCIS terms and browsed as a distinct vocabulary. This is NOT the BatteryPass Consortium SAMM data model (urn:samm:io.BatteryPass.*, v1.2.x), which is a separate source."@en ;
    dcterms:source <https://thebatterypass.eu/battery-pass-ready/publications/> ;
    owl:versionInfo "1.3 (longlist); GEFEG validation data model v1.0" .

# IdentifiersAndProductData
<https://ref.openepcis.io/vocab/batterypass-ready/1.3#BatteryCategory>
    a rdf:Property ;
    rdfs:label "Battery Category"@en ;
    rdfs:comment "Categories relevant for the battery passport: LMT battery, ?electric vehicle battery, stationary or other industrial battery >2kWh.\n\nDIN DKE Spec chapter reference: 6.1.3.5"@en ;
    skos:definition "Categories relevant for the battery passport: LMT battery, ?electric vehicle battery, stationary or other industrial battery >2kWh.\n\nDIN DKE Spec chapter reference: 6.1.3.5"@en ;
    skos:note "GEFEG BatteryPass-Ready longlist v1.3 attribute (group IdentifiersAndProductData). Definition sourced from the corresponding BatteryPass Consortium SAMM property (io.BatteryPass.*), which the longlist derives from."@en ;
    rdfs:isDefinedBy <https://ref.openepcis.io/vocab/batterypass-ready/1.3> ;
    dcterms:source <https://thebatterypass.eu/battery-pass-ready/publications/> .

<https://ref.openepcis.io/vocab/batterypass-ready/1.3#BatteryMass>
    a rdf:Property ;
    rdfs:label "Battery Mass"@en ;
    rdfs:comment "Mass of the entire battery in kilograms. Voluntary: if the battery is defined on pack or module level: also weight of the modules and/or cells.\n\nDIN DKE Spec chapter reference: 6.1.3.6"@en ;
    skos:definition "Mass of the entire battery in kilograms. Voluntary: if the battery is defined on pack or module level: also weight of the modules and/or cells.\n\nDIN DKE Spec chapter reference: 6.1.3.6"@en ;
    skos:note "GEFEG BatteryPass-Ready longlist v1.3 attribute (group IdentifiersAndProductData). Definition sourced from the corresponding BatteryPass Consortium SAMM property (io.BatteryPass.*), which the longlist derives from."@en ;
    rdfs:isDefinedBy <https://ref.openepcis.io/vocab/batterypass-ready/1.3> ;
    dcterms:source <https://thebatterypass.eu/battery-pass-ready/publications/> .

<https://ref.openepcis.io/vocab/batterypass-ready/1.3#BatteryModelIdentifier>
    a rdf:Property ;
