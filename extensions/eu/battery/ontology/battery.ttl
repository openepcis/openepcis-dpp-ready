# =============================================================================

eubat:dataQualityAssessment
    a owl:DatatypeProperty ;
    rdfs:label "Data Quality Assessment"@en ;
    rdfs:comment "Assessment of data quality and completeness (A-E rating)."@en ;
    rdfs:domain gs1:Product ;
