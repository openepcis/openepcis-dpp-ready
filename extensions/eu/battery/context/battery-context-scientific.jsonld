{
  "@context": [
    {
      "@version": 1.1,
      "gs1": "https://ref.gs1.org/voc/",
      "eubat": "https://ref.openepcis.io/extensions/eu/battery/",
      "schema": "https://schema.org/",
      "xsd": "http://www.w3.org/2001/XMLSchema#",
      "hasBattery": {
        "@id": "eubat:hasBattery",
        "@type": "@id"
      }
    },
    {
      "@version": 1.1,
      "battinfo": "https://w3id.org/emmo/domain/battery#",
      "qudt": "http://qudt.org/schema/qudt/",
      "unit": "http://qudt.org/vocab/unit/",
      "owl": "http://www.w3.org/2002/07/owl#",

      "eubat:stateOfHealth": {
        "@id": "eubat:stateOfHealth",
        "owl:equivalentProperty": { "@id": "battinfo:StateOfHealth" }
      },
      "eubat:stateOfCharge": {
        "@id": "eubat:stateOfCharge",
        "owl:equivalentProperty": { "@id": "battinfo:StateOfCharge" }
      },
      "eubat:cycleCount": {
        "@id": "eubat:cycleCount",
        "owl:equivalentProperty": { "@id": "battinfo:CycleNumber" }
      },
      "eubat:remainingCapacity": {
        "@id": "eubat:remainingCapacity",
        "owl:equivalentProperty": { "@id": "battinfo:Capacity" }
      },
      "eubat:internalResistance": {
        "@id": "eubat:internalResistance",
        "owl:equivalentProperty": { "@id": "battinfo:InternalResistance" }
      },

      "eubat:Cathode": {
        "@id": "eubat:Cathode",
        "owl:equivalentClass": { "@id": "battinfo:Cathode" }
      },
      "eubat:Anode": {
        "@id": "eubat:Anode",
        "owl:equivalentClass": { "@id": "battinfo:Anode" }
      },
      "eubat:Electrolyte": {
        "@id": "eubat:Electrolyte",
        "owl:equivalentClass": { "@id": "battinfo:Electrolyte" }
      },
      "eubat:Separator": {
        "@id": "eubat:Separator",
        "owl:equivalentClass": { "@id": "battinfo:Separator" }
      },

      "AH": {
        "@id": "unit:A-HR",
        "qudt:symbol": "Ah"
      },
      "KWH": {
        "@id": "unit:KiloW-HR",
        "qudt:symbol": "kWh"
      },
      "VLT": {
        "@id": "unit:V",
        "qudt:symbol": "V"
      },
      "KWT": {
        "@id": "unit:KiloW",
        "qudt:symbol": "kW"
      },
      "OHM": {
        "@id": "unit:OHM",
        "qudt:symbol": "Ω"
      },
      "CEL": {
        "@id": "unit:DEG_C",
        "qudt:symbol": "°C"
      },
      "KGM": {
        "@id": "unit:KiloGM",
        "qudt:symbol": "kg"
      },
      "P1": {
        "@id": "unit:PERCENT",
        "qudt:symbol": "%"
      }
    }
  ]
}
