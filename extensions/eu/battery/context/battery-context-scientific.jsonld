{
  "@context": [
    {
      "@version": 1.1,
      "gs1": "https://ref.gs1.org/voc/",
      "battery": "https://ref.openepcis.io/extensions/eu/battery/",
      "schema": "https://schema.org/",
      "xsd": "http://www.w3.org/2001/XMLSchema#",
      "hasBattery": {
        "@id": "battery:hasBattery",
        "@type": "@id"
      }
    },
    {
      "@version": 1.1,
      "battinfo": "https://w3id.org/emmo/domain/battery#",
      "qudt": "http://qudt.org/schema/qudt/",
      "unit": "http://qudt.org/vocab/unit/",
      "owl": "http://www.w3.org/2002/07/owl#",

      "battery:stateOfHealth": {
        "@id": "battery:stateOfHealth",
        "owl:equivalentProperty": { "@id": "battinfo:StateOfHealth" }
      },
      "battery:stateOfCharge": {
        "@id": "battery:stateOfCharge",
        "owl:equivalentProperty": { "@id": "battinfo:StateOfCharge" }
      },
      "battery:cycleCount": {
        "@id": "battery:cycleCount",
        "owl:equivalentProperty": { "@id": "battinfo:CycleNumber" }
      },
      "battery:remainingCapacity": {
        "@id": "battery:remainingCapacity",
        "owl:equivalentProperty": { "@id": "battinfo:Capacity" }
      },
      "battery:internalResistance": {
        "@id": "battery:internalResistance",
        "owl:equivalentProperty": { "@id": "battinfo:InternalResistance" }
      },

      "battery:Cathode": {
        "@id": "battery:Cathode",
        "owl:equivalentClass": { "@id": "battinfo:Cathode" }
      },
      "battery:Anode": {
        "@id": "battery:Anode",
        "owl:equivalentClass": { "@id": "battinfo:Anode" }
      },
      "battery:Electrolyte": {
        "@id": "battery:Electrolyte",
        "owl:equivalentClass": { "@id": "battinfo:Electrolyte" }
      },
      "battery:Separator": {
        "@id": "battery:Separator",
        "owl:equivalentClass": { "@id": "battinfo:Separator" }
      },

      "AH": {
        "@id": "unit:A-HR",
        "qudt:symbol": "Ah"
      },
      "KWH": {
        "@id": "unit:KiloW-HR",
        "qudt:symbol": "kWh"
      },
      "VLT": {
        "@id": "unit:V",
        "qudt:symbol": "V"
      },
      "KWT": {
        "@id": "unit:KiloW",
        "qudt:symbol": "kW"
      },
      "OHM": {
        "@id": "unit:OHM",
        "qudt:symbol": "Ω"
      },
      "CEL": {
        "@id": "unit:DEG_C",
        "qudt:symbol": "°C"
      },
      "KGM": {
        "@id": "unit:KiloGM",
        "qudt:symbol": "kg"
      },
      "P1": {
        "@id": "unit:PERCENT",
        "qudt:symbol": "%"
      }
    }
  ]
}
