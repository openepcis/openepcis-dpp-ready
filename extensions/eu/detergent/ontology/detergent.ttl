    skos:note "Detergent ingredient / substance disclosure per the EU Detergents Regulation (EU) 2026/405 (ingredient data sheet). No GS1, SEMICeu, or schema.org equivalent."@en .

eudet:allergenConcentration
    a owl:DatatypeProperty ;
    rdfs:label "Allergen Concentration"@en ;
    rdfs:comment "Concentration of the allergen as weight percentage."@en ;
    rdfs:domain eudet:FragranceAllergen ;
    rdfs:range xsd:decimal ;
    rdfs:isDefinedBy <https://ref.openepcis.io/extensions/eu/detergent/> ;
    dcterms:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32026R0405> ;
    skos:note "Detergent ingredient / substance disclosure per the EU Detergents Regulation (EU) 2026/405 (ingredient data sheet). No GS1, SEMICeu, or schema.org equivalent."@en .

# =============================================================================
# Microorganism Properties (Article 19)
# =============================================================================

eudet:strainDesignation
    a owl:DatatypeProperty ;
    rdfs:label "Strain Designation"@en ;
    rdfs:comment "Specific strain designation or collection number."@en ;
    rdfs:domain eudet:MicroorganismInfo ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://ref.openepcis.io/extensions/eu/detergent/> ;
    dcterms:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32026R0405> ;
    skos:note "EU Detergents Regulation (EU) 2026/405 attribute. No GS1, SEMICeu, or schema.org equivalent."@en .

eudet:endProductCharacteristics
    a owl:DatatypeProperty ;
    rdfs:label "End Product Characteristics"@en ;
    rdfs:comment "Description of the end product characteristics of the microorganism (enzymes produced, metabolites, etc.)."@en ;
    rdfs:domain eudet:MicroorganismInfo ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://ref.openepcis.io/extensions/eu/detergent/> ;
    dcterms:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32026R0405> ;
    skos:note "EU Detergents Regulation (EU) 2026/405 attribute. No GS1, SEMICeu, or schema.org equivalent."@en .

# =============================================================================
# Cross-cutting alignment to oec: (Phase 2 lift)
# =============================================================================

# CLP signal-word and pictogram terms align to the lifted oec: equivalents on
# oec:HazardousSubstance.
eudet:SignalWord            owl:equivalentClass    oec:HazardSignalWord .
eudet:Danger                owl:equivalentClass    oec:HazardDanger .
eudet:Warning               owl:equivalentClass    oec:HazardWarning .
eudet:signalWord            owl:equivalentProperty oec:hazardSignalWord .
eudet:hazardPictograms      owl:equivalentProperty oec:hazardPictogramCode .
eudet:hStatements           owl:equivalentProperty oec:hazardStatement .
eudet:pStatements           owl:equivalentProperty oec:precautionaryStatement .

# Biodegradability test result aligns to the lifted oec:Biodegradability.
eudet:SurfactantBiodegradability rdfs:subClassOf       oec:Biodegradability .
eudet:biodegradationPercentage   owl:equivalentProperty oec:biodegradationPercentage .
eudet:biodegradabilityTestMethod owl:equivalentProperty oec:biodegradabilityTestMethod .
