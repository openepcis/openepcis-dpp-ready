                "regulationType": {
                  "id": "euppwr:RegulationTypeCode-PACKAGING_AND_PACKAGING_WASTE_REGULATION"
                },
                "regulatoryAct": "EU 2025/40 Annex II",
                "isRegulationCompliant": true
              }
            ]
          }
        ],
        "sensorElementList": [
          {
