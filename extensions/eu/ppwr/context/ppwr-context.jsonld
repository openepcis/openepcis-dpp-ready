{
  "_comment": "OpenEPCIS PPWR Vocabulary v0.1.0, EU Regulation 2025/40. Module is intentionally thin; nearly every PPWR data point reuses the lifted oec: cross-cutting terms (ExtendedProducerResponsibility, Compostability, Biodegradability, DepositReturnScheme, bioBasedFraction, RecycledContent, HazardousSubstance) plus untp: (Facility, Material, Claim) and gs1: (Packaging, regulatoryInformation). Only packaging-specific terms (Packaging, packagingTier, recyclabilityGrade, harmonisedSymbol) live in the euppwr: namespace.",
  "@context": [
    "https://ref.openepcis.io/extensions/common/core/dpp-core-context.jsonld",
    {
      "@version": 1.1,
      "euppwr": "https://ref.openepcis.io/extensions/eu/ppwr/",
      "oec": "https://ref.openepcis.io/extensions/common/core/",
      "gs1": "https://ref.gs1.org/voc/",
      "schema": "https://schema.org/",
      "xsd": "http://www.w3.org/2001/XMLSchema#",
      "id": "@id",
      "type": "@type",
      "manufacturer": {
        "@id": "gs1:manufacturer",
        "@type": "@id"
      },
      "regulatoryInformation": {
        "@id": "gs1:regulatoryInformation",
        "@type": "@id",
        "@container": "@set"
      },
      "RegulatoryInformation": "gs1:RegulatoryInformation",
      "regulationType": {
        "@id": "gs1:regulationType",
        "@type": "@id"
      },
      "regulatoryAct": "gs1:regulatoryAct",
      "isRegulationCompliant": {
        "@id": "oec:isRegulationCompliant",
        "@type": "xsd:boolean"
      },
      "Packaging": "euppwr:Packaging",
      "packagingTier": {
        "@id": "euppwr:packagingTier",
        "@type": "@vocab",
        "@context": {
          "Sales": "euppwr:Sales",
          "Grouped": "euppwr:Grouped",
          "Transport": "euppwr:Transport"
        }
      },
      "recyclabilityGrade": {
        "@id": "euppwr:recyclabilityGrade",
        "@type": "@vocab",
        "@context": {
          "A": "euppwr:GradeA",
          "B": "euppwr:GradeB",
          "C": "euppwr:GradeC"
        }
      },
      "harmonisedSymbol": {
        "@id": "euppwr:harmonisedSymbol",
        "@type": "xsd:anyURI"
      },
      "PackagingTier": "euppwr:PackagingTier",
      "RecyclabilityGrade": "euppwr:RecyclabilityGrade",
      "QuantitativeValue": "gs1:QuantitativeValue"
    }
  ]
}
