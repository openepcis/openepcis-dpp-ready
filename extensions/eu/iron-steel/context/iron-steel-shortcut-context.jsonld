{
  "_comment": [
    "Bare (unprefixed) term aliases for the iron-steel vocabulary.",
    "Included only by the operational contexts, so bare terms resolve under an",
    "operational @context but the standard context requires proper prefixing."
  ],
  "@context": {
    "@version": 1.1,
    "eusteel": "https://ref.openepcis.io/extensions/eu/iron-steel/",
    "gs1": "https://ref.gs1.org/voc/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "oec": "https://ref.openepcis.io/extensions/common/core/",
    "schema": "https://schema.org/",
    "IronSteelProduct": "eusteel:IronSteelProduct",
    "MaterialTestCertificate": "eusteel:MaterialTestCertificate",
    "TechnologyRoute": "eusteel:TechnologyRoute",
    "castNumber": {
      "@id": "eusteel:castNumber",
      "@type": "xsd:string"
    },
    "cbamReportId": {
      "@id": "eusteel:cbamReportId",
      "@type": "xsd:string"
    },
    "heatNumber": {
      "@id": "eusteel:heatNumber",
      "@type": "xsd:string"
    },
    "lotNumber": {
      "@id": "eusteel:lotNumber",
      "@type": "xsd:string"
    },
    "meltAndPourCountry": {
      "@id": "eusteel:meltAndPourCountry",
      "@type": "xsd:string"
    },
    "mtc": {
      "@id": "eusteel:mtc",
      "@type": "@id"
    },
    "mtcCarbonContent": {
      "@id": "eusteel:mtcCarbonContent",
      "@type": "xsd:decimal"
    },
    "mtcCarbonEquivalent": {
      "@id": "eusteel:mtcCarbonEquivalent",
      "@type": "xsd:decimal"
    },
    "mtcCopperContent": {
      "@id": "eusteel:mtcCopperContent",
      "@type": "xsd:decimal"
    },
    "mtcElongation": {
      "@id": "eusteel:mtcElongation",
      "@type": "xsd:decimal"
    },
    "mtcFinishing": {
      "@id": "eusteel:mtcFinishing",
      "@type": "xsd:string"
    },
    "mtcInspectionType": {
      "@id": "eusteel:mtcInspectionType",
      "@type": "xsd:string"
    },
    "mtcNitrogenContent": {
      "@id": "eusteel:mtcNitrogenContent",
      "@type": "xsd:decimal"
    },
    "mtcNominalSize": {
      "@id": "eusteel:mtcNominalSize",
      "@type": "xsd:decimal"
    },
    "mtcPhosphorusContent": {
      "@id": "eusteel:mtcPhosphorusContent",
      "@type": "xsd:decimal"
    },
    "mtcRadiometricControl": {
      "@id": "eusteel:mtcRadiometricControl",
      "@type": "xsd:decimal"
    },
    "mtcRelativeRibArea": {
      "@id": "eusteel:mtcRelativeRibArea",
      "@type": "xsd:decimal"
    },
    "mtcSteelProcess": {
      "@id": "eusteel:mtcSteelProcess",
      "@type": "xsd:string"
    },
    "mtcSulfurContent": {
      "@id": "eusteel:mtcSulfurContent",
      "@type": "xsd:decimal"
    },
    "mtcTensileStrength": {
      "@id": "eusteel:mtcTensileStrength",
      "@type": "xsd:decimal"
    },
    "mtcWeightTolerance": {
      "@id": "eusteel:mtcWeightTolerance",
      "@type": "xsd:decimal"
    },
    "mtcYieldStrength": {
      "@id": "eusteel:mtcYieldStrength",
      "@type": "xsd:decimal"
    },
    "mtcYieldStrengthRatio": {
      "@id": "eusteel:mtcYieldStrengthRatio",
      "@type": "xsd:decimal"
    },
    "productNumber": {
      "@id": "eusteel:productNumber",
      "@type": "xsd:string"
    },
    "purchaserOrder": {
      "@id": "eusteel:purchaserOrder",
      "@type": "xsd:string"
    },
    "steelDesignation": {
      "@id": "eusteel:steelDesignation",
      "@type": "xsd:string"
    },
    "steelGradeClassification": {
      "@id": "eusteel:steelGradeClassification",
      "@type": "xsd:string"
    },
    "technologyRoute": {
      "@id": "eusteel:technologyRoute",
      "@type": "@vocab",
      "@context": {
        "BF-BOF": "eusteel:BlastFurnaceBOF",
        "EAF": "eusteel:ElectricArcFurnace",
        "OHF": "eusteel:OpenHearthFurnace",
        "other": "eusteel:OtherRoute"
      }
    }
  }
}
