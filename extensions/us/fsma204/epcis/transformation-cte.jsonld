  "_comment_gs1us_mapping": [
    "Transformation CTE per GS1 US 'EPCIS Recommendations for FSMA 204 CTEs' R2.0, §5.",
    "A single TransformationEvent captures:",
    "  bizStep = creating_class_instance, disposition = active.",
    "  inputQuantityList = each ingredient TLC (GTIN+Batch/Lot) + quantity/uom.",
    "  outputQuantityList = the new TLC of the produced food + quantity/uom.",
    "  readPoint + bizLocation = transformation location GLN = TLC source.",
    "  eventTime = date transformation was completed.",
    "  bizTransactionList = reference document KDEs.",
    "  ilmd may carry trade item-level attributes such as gs1:bestBeforeDate.",
    "NO fsma: extension fields ride inside the event."
  ],
