  "_comment_gs1us_mapping": [
    "Harvest CTE per GS1 US 'EPCIS Recommendations for FSMA 204 CTEs' R2.0, §2.",
    "Event 1 = harvesting itself: ObjectEvent, action=ADD, bizStep=creating_class_instance, disposition=active.",
    "  readPoint = Location GLN of the farm where the food was harvested (KDE).",
    "  bizLocation = Location GLN of the field / growing area / aquaculture container (KDE).",
    "  quantityList.epcClass = GS1 Digital Link of GTIN+Batch/Lot (commodity + variety KDE).",
    "  quantityList.quantity + uom = quantity and unit of measure KDE.",
    "  eventTime = date of harvesting KDE.",
    "  bizTransactionList = reference document type + number KDEs.",
    "Event 2 = transport to the immediate subsequent recipient:",
    "  ObjectEvent, action=OBSERVE, bizStep=transporting, disposition=in_transit.",
    "  sourceList type=owning_party = harvester business identity KDE (phone etc. ride in master data of the GLN).",
    "  destinationList type=location = immediate subsequent recipient location KDE.",
    "NO fsma: extension fields ride inside the event — everything maps onto native EPCIS/GS1 fields."
  ],
