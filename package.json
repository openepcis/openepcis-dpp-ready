{
  "name": "openepcis-dpp-ready",
  "version": "0.9.7",
  "description": "OpenEPCIS Digital Product Passport Ontologies",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsx scripts/build-json.ts && tsx scripts/check-vocab.ts && tsx scripts/check-granularity.ts && tsx scripts/check-identifiers.ts",
    "build:json": "tsx scripts/build-json.ts",
    "check:vocab": "tsx scripts/check-vocab.ts",
    "check:granularity": "tsx scripts/check-granularity.ts",
    "check:identifiers": "tsx scripts/check-identifiers.ts",
    "sync:vocab": "tsx scripts/check-vocab.ts --sync",
    "build:context": "tsx scripts/build-context.ts",
    "build:batterypass-schema": "tsx scripts/build-batterypass-schema.ts",
    "export:batterypass-gefeg": "tsx scripts/export-batterypass-gefeg.ts",
    "reconstruct:batterypass": "tsx scripts/reconstruct-passport-from-epcis.ts",
    "build:batterypass-ready-vocab": "tsx scripts/build-batterypass-ready-vocab.ts",
    "build:batterypass-samm-terms": "tsx scripts/build-batterypass-samm-terms.ts",
    "build:gefeg-live-schema": "tsx scripts/build-gefeg-live-schema.ts",
    "validate:batterypass-live": "tsx scripts/validate-batterypass-live.ts",
    "probe:gefeg-required": "tsx scripts/probe-gefeg-required.ts",
    "test": "tsx scripts/test-batterypass-conformance.ts",
    "validate:examples": "tsx scripts/validate-jsonld-examples.ts",
    "derive:en18223": "tsx scripts/derive-en18223.ts",
    "demo:en18223:data": "tsx scripts/build-en18223-demo-data.ts",
    "demo:en18223:build": "pnpm run demo:en18223:data && esbuild demos/en18223-converter/app.ts --bundle --format=esm --platform=browser --loader:.jsonld=json --outfile=demos/en18223-converter/app.js",
    "demo:en18223": "pnpm run demo:en18223:build && esbuild demos/en18223-converter/app.ts --bundle --format=esm --platform=browser --loader:.jsonld=json --servedir=demos/en18223-converter --outfile=demos/en18223-converter/app.js",
    "sync:rail": "tsx scripts/sync-rail.ts",
    "diagrams:build": "tsx scripts/build-diagrams.ts"
  },
  "devDependencies": {
    "@types/jsonld": "^1.5.15",
    "@types/n3": "^1.21.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.0",
    "jsonld": "^9.0.0",
    "n3": "^1.22.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
