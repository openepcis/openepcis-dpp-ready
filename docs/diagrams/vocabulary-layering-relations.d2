# Source for vocabulary-layering-relations-{light,dark}.svg — `pnpm run diagrams:build`.
# A worked example of the delegation pattern: one regulation-module term cascades
# through the shared core (oec:) up to the foundational and upstream vocabularies.
# The full term-by-term anchor list lives in the prose below the diagram.

direction: up

classes: {
  l1: { style: { fill: "#dbeafe"; stroke: "#1e40af"; stroke-width: 2; font-color: "#0f172a" } }
  l2: { style: { fill: "#fef3c7"; stroke: "#92400e"; font-color: "#0f172a" } }
  l3: { style: { fill: "#dcfce7"; stroke: "#166534"; font-color: "#0f172a" } }
  l4: { style: { fill: "#fce7f3"; stroke: "#9d174d"; font-color: "#0f172a" } }
}

spin: "eutex:spinningFacility\nLayer 4 · a textile spinning site" { class: l4 }
fac: "oec:FacilityInformation\nLayer 3 · shared DPP facility concept" { class: l3 }
gs1place: "gs1:Place\nLayer 1 · GS1" { class: l1 }
untpfac: "untp:Facility\nLayer 2 · UNTP" { class: l2 }
locn: "locn:Location\nLayer 1 · SEMICeu" { class: l1 }

spin -> fac: "ranges to"
fac -> gs1place: "rdfs:subClassOf"
fac -> untpfac: "skos:exactMatch" { style.stroke-dash: 3 }
fac -> locn: "rdfs:seeAlso" { style.stroke-dash: 3 }
