# Source for vocabulary-layering-overview-{light,dark}.svg — `pnpm run diagrams:build`.
# Condensed four-layer delegation stack for the top-level README.md.

direction: down

l4: "Layer 4 — Regulation modules\n(eu/battery, eu/eudr, eu/textile, eu/electronics,\neu/detergent, eu/ppwr, eu/cpr, us/fsma204)"

l3: "Layer 3 — Common DPP core (oec:)\ncross-cutting concepts ≥2 regs share"

l2: "Layer 2 — Upstream community profiles\nUNTP v0.7.0  Party, Facility, Material, Claim,\n             ConformityAttestation, PerformanceMetric, …\nCIRPASS-2 D3.x; CEN/CENELEC JTC 24 (EN 18216-18223)"

l1: "Layer 1 — Foundational vocabularies (peer triumvirate)\nGS1 (gs1:)   Product, Organization, Place, GeoShape,\n             regulatoryInformation, UN/CEFACT unit codes\n             (imported foundation, owl:imports)\nSEMICeu      cv:PublicOrganisation, cv:ContactPoint,\n             cv:LegalEntity, cccev:Requirement,\n             cccev:Evidence, locn:Location, adms:Identifier\nschema.org   Observation, QuantitativeValue, GeoCoordinates,\n             Country, Rating, hasMeasurement"

l4 -> l3
l3 -> l2: "owl:equivalentClass / equivalentProperty"
l2 -> l1
