vars {
  url: https://api.demo.epcis.cloud
  dl-url: https://id.demo.epcis.cloud
  ddm-host: https://demo.epcis.cloud
  keycloak: https://auth.demo.epcis.cloud
  accessTokenUrl: https://auth.demo.epcis.cloud/realms/openepcis/protocol/openid-connect/token
  jwtScope: openid roles
  username: demo-admin
  clientId: backend-service
  dpp-context: https://ref.openepcis.io/extensions/common/core/dpp-core-context.jsonld
  battery-context: https://ref.openepcis.io/extensions/eu/battery/battery-context.jsonld
  textile-context: https://ref.openepcis.io/extensions/eu/textile/textile-context.jsonld
  gs1-extensions: dpp=https://ref.openepcis.io/extensions/common/core/,textile=https://ref.openepcis.io/extensions/eu/textile/,battery=https://ref.openepcis.io/extensions/eu/battery/
}

vars:secret [
  password,
  clientSecret
]
