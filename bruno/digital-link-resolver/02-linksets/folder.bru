meta {
  name: Linksets
  seq: 2
}

headers {
  Content-Type: application/json
}

auth {
  mode: oauth2
}

auth:oauth2 {
  grant_type: password
  access_token_url: {{accessTokenUrl}}
  username: {{username}}
  password: {{password}}
  client_id: {{clientId}}
  client_secret: {{clientSecret}}
  scope: {{jwtScope}}
}
